xt":13},{"text":336,"url":337,"target":80,"ariaLabel":28},"Frontiers Instagram","https://www.instagram.com/frontiersin_","Instagram","Frontiers Media SA. All rights reserved.","https://www.frontiersin.org/legal/terms-and-conditions","https://www.frontiersin.org/legal/privacy-policy","https://www.frontiersin.org/about/accessibility-statement",{},false,{"__typename":346,"identifier":119,"name":120,"slug":121,"banner":347,"description":404,"mission":405,"palette":406,"impactFactor":407,"citeScore":408,"citations":409,"showTagline":28,"twitter":410},"Journal",[348],{"id":349,"src":350,"name":351,"tags":352,"type":362,"width":363,"height":364,"idHash":365,"archive":366,"brandId":367,"limited":366,"fileSize":368,"isPublic":369,"original":370,"copyright":371,"extension":372,"thumbnails":374,"dateCreated":382,"description":383,"orientation":384,"userCreated":385,"watermarked":366,"dateModified":382,"datePublished":386,"ecsArchiveFiles":387,"propertyOptions":388,"property_Channel":393,"property_Sub-Type":395,"property_Asset_Type":397,"activeOriginalFocusPoint":399,"property_Office_Department":402},"7CCE4235-8BF4-4D52-8022020C57AC98C1","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/webimage-F7837330-160A-426F-A7EBDF4B8DECDD06.png","FPUBH_Main Visual_Cyan_Website",[353,354,355,356,357,358,359,360,361],"pandemic","c","safety","danger","smartphone","commuter","mode","inside","barrier","image",3745,2497,"199032aaf8eef874",0,"22C10171-81B3-4DA6-99342F272A32E8BB",6620585,1,"https://brand.frontiersin.org/m/199032aaf8eef874/original/FPUBH_Main-Visual_Cyan_Website.jpg","Copyright (c) 2020 SmartPhotoLab/Shutterstock.  No use without permission.",[373],"jpg",{"mini":375,"thul":376,"webimage":350,"Guidelines":377,"WebsiteJpg_XL":378,"WebsiteWebP_L":379,"WebsiteWebP_M":380,"WebsiteWebP_XL":381},"https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/mini-50226AC5-79DE-4DE1-ACC02582A564B0E1.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/thul-B46E7F8F-CAF8-4A31-B91A262CA70C16DB.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/D992F897-6BC2-466D-90902EADFBEAB887/Guidelines-FPUBH_Main Visual_Cyan_Website.png","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/D992F897-6BC2-466D-90902EADFBEAB887/WebsiteJpg_XL-FPUBH_Main Visual_Cyan_Website.jpg","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/D992F897-6BC2-466D-90902EADFBEAB887/WebsiteWebP_L-FPUBH_Main Visual_Cyan_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/D992F897-6BC2-466D-90902EADFBEAB887/WebsiteWebP_M-FPUBH_Main Visual_Cyan_Website.webp","https://d2csxpduxe849s.cloudfront.net/media/E32629C6-9347-4F84-81FEAEF7BFA342B3/7CCE4235-8BF4-4D52-8022020C57AC98C1/D992F897-6BC2-466D-90902EADFBEAB887/WebsiteWebP_XL-FPUBH_Main Visual_Cyan_Website.webp","2022-06-27T10:00:52Z","variety of passengers ride the subway car","landscape","Caroline Sutter","2022-06-27T09:27:09Z",[],[389,390,391,392],"414FB2D4-2283-43FD-BE14E534ECA67928","6C18119B-14BD-4951-B437696F4357BD33","7C692885-DB25-4858-B1FB4FF47B241E9B","D88C0047-EC30-4506-A7DF28A4D765E1CF",[394],"frontiersin_org",[396],"Main_Visual",[398],"Photography",{"x":400,"y":401},1873,1249,[403],"Publishing","Explore open access research in public health, advancing prevention, policy, systems and population health strategies worldwide.","\u003Cp>Frontiers in Public Health publishes developments in all fields of public health research, aiming to advance our understanding of causal relationships for disease, promote community-based interventions and explore prevention at the community and individual level.\u003C/p>\n\n\u003Cp>Led by Field Chief Editor Paolo Vineis of Imperial College London, United Kingdom, Frontiers in Public Health welcomes submissions across all areas of the field that advances population health, furthers disease prevention and promotes health for all members of society. Topics include:\u003C/p>\n \n\u003Cdiv> &bull; aging and public health\u003C/div>\n\u003Cdiv> &bull; children and health\u003C/div>\n\u003Cdiv> &bull; digital public health\u003C/div>\n\u003Cdiv> &bull; disaster and emergency medicine\u003C/div>\n\u003Cdiv> &bull; environmental health and exposome\u003C/div>\n\u003Cdiv> &bull; health economics\u003C/div>\n\u003Cdiv> &bull; infectious diseases: epidemiology and prevention\u003C/div>\n\u003Cdiv> &bull; injury prevention and control\u003C/div>\n\u003Cdiv> &bull; life-course epidemiology and social inequalities in health\u003C/div>\n\u003Cdiv> &bull; occupational health and safety\u003C/div>\n\u003Cdiv> &bull; planetary health\u003C/div>\n\u003Cdiv> &bull; public health education and promotion\u003C/div>\n\u003Cdiv> &bull; public health policy\u003C/div>\n\u003Cdiv> &bull; public health and nutrition\u003C/div>\n\u003Cdiv> &bull; public mental health\u003C/div>\n\u003Cdiv> &bull; radiation and health\u003C/div>\n\u003Cdiv> &bull; substance use disorders and behavioral addictions.\u003C/div>\n \u003Cbr>\n\u003Cp>The journal welcomes submissions which advance the UN’s Sustainable Development Goals (SDG), notably SDG 3, Good Health and Well-Being, in the effort to address significant global public health concerns, preparedness and develop appropriate mitigation measures.\u003C/p>\n\n\u003Cp>Manuscripts that focus solely on health services, clinical trials on drugs, medical imaging, and disease-specific studies that do not have a clear public health relevance, are not suitable for publication in this journal. Additionally, studies that are purely predictive or prognostic models without a relevance to public health practice or policy will not be considered. The journal does not accept papers concerning simple bibliometric studies and discourages publication of cross-sectional studies, with exceptions. Authors are welcome to submit Systematic Reviews using publicly available data, but these must adhere to the PRISMA guidelines and have a conclusion related to public health. Manuscripts reporting findings from Mendelian Randomization studies need to be accompanied by a completed \u003Ca href=\"https://www.strobe-mr.org/\">STROBE-MR checklist\u003C/a>.\u003C/p>\n\n\u003Cp>Frontiers’ journals require that manuscripts primarily comprising computational studies of public data, must include appropriate validation. Please refer to the \u003Ca href=\"https://www.frontiersin.org/guidelines/policies-and-publication-ethics#standards-for-research-methodology:~:text=complaints%20and%20allegations.-,Standards%20for%20research%20methodology,-Experiments\">Frontiers Standards for research methodology policy\u003C/a>, for more information. Manuscripts not adhering to these standards will not be considered.\u003Cp>\n\n\u003Cp>Frontiers in Public Health is committed to advancing developments in the field of public health by allowing unrestricted access to articles, welcoming trials on public health interventions, and communicating scientific knowledge to researchers and the public alike, to enable the scientific breakthroughs of the future.\u003C/p>\n\n— \n\n\u003Cp>\u003Cstrong>Ethics Statement for the Tobacco Industry\u003C/strong>\u003C/p>\n \n\u003Cp>In accordance with Frontiers’ Conflict of Interest (COI) policy, for any research article that is sponsored through commercial funding, the role of the funder must be declared to Frontiers in Public Health in full. If that source of funding is tied to the vested interests of the tobacco or commercial nicotine industries or affiliated organisations, it will be rejected without passing into peer review.\u003C/p>\n\n\u003Cp>If undeclared funding information of this type comes to light post-publication, a formal correction or retraction in full will take place. If a researcher has past or present affiliations or has received incentives from commercial tobacco or nicotine industries or affiliated organisations, the research article will not pass into peer review.\u003C/p>\n\n\u003Cp>For industries other than tobacco or commercial nicotine, a case-by-case evaluation will be made at Editorial level. There are potential situations of conflict of interest arising e.g. from the food or cosmetics industry or other industries that produce goods that are under scrutiny for safety or that may contribute to ill health.\u003C/p>\n\n\u003Cp>Examples of competing interests include the following: board membership, consultancy, employment, expert testimony grants (including pending), contract research, lectures/other education events, speakers’ bureaux, patents (planned, pending or issued), receipt of equipment or supplies, royalties, stock/stock options/other forms of ownership, additional expenses not included in COIs already specified, other personal or professional relationships that may influence or appear to influence.\u003C/p>\n\n\u003Cp>For more information on Frontiers VALID acceptance criteria see: https://www.frontiersin.org/about/review-system.\u003C/p>","cyan","5.2","3.8","377118","@FrontPubHealth",{"id":119,"name":120,"slug":121,"abbreviation":412,"isOnline":13,"isOpenForSubmissions":13,"citeScore":413,"impactFactor":414},"fpubh",6.4,4.1,{"displayTitlePillLabels":13,"displayRelatedArticlesBox":13,"showEditors":13,"showReviewers":13,"showLoopImpactLink":13,"enableFigshare":344},{"isPublic":344,"allowCompanyUsers":344,"whiteListEmails":417,"enableAllJournals":344,"whiteListJournals":418},[],[],{"spaceId":369,"name":369,"availableJournalPages":420,"announcement":424,"useJournalPalettes":344},[251,256,253,421,422,423],"volumes","about","community-reviewers",{"__typename":425,"sys":426,"preHeader":428,"title":429,"description":430,"image":431,"link":475},"Announcement",{"id":427},"4Ykr50JbNkmlF9eDayZLTg","our impact","Your research is the real superpower","Behind each article we publish stands a team of superheroes: authors, editors, and reviewers who chose to uphold quality standards and share knowledge openly. Read more about the impact your work achieves.",[432],{"archive":366,"brandId":367,"copyright":28,"dateCreated":433,"dateModified":434,"datePublished":435,"description":436,"extension":437,"fileSize":438,"height":439,"id":440,"isPublic":369,"limited":366,"name":436,"orientation":384,"original":441,"thumbnails":442,"type":362,"watermarked":366,"width":451,"videoPreviewURLs":452,"streamingLinks":453,"tags":454,"selectedFile":28,"textMetaproperties":474,"src":443},"2022-04-05T17:21:12Z","2026-02-11T15:32:48Z","2022-04-08T15:08:44Z","Winter ice diving underwater in a quarry in Canada",[373],14594526,2848,"AF8621E4-5094-42D6-AAE7397EBC5E76DF","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/Winter-ice-diving-underwater-in-a-quarry-in-Canada.jpg",{"webimage":443,"thul":444,"mini":445,"Guidelines":446,"WebsiteWebP_L":447,"WebsiteWebP_XL":448,"WebsiteJpg_XL":449,"original":441,"WebsiteWebP_M":450},"https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/thumbnail/webimage-Winter-ice-diving-underwater-in-a-quarry-in-Canada","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/thumbnail/thul-Winter-ice-diving-underwater-in-a-quarry-in-Canada","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/thumbnail/mini-Winter-ice-diving-underwater-in-a-quarry-in-Canada","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/Guidelines/Winter-ice-diving-underwater-in-a-quarry-in-Canada.png","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/WebsiteWebP_L/Winter-ice-diving-underwater-in-a-quarry-in-Canada.webp","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/WebsiteWebP_XL/Winter-ice-diving-underwater-in-a-quarry-in-Canada.webp","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/WebsiteJpg_XL/Winter-ice-diving-underwater-in-a-quarry-in-Canada.jpg","https://brand.frontiersin.org/asset/af8621e4-5094-42d6-aae7-397ebc5e76df/WebsiteWebP_M/Winter-ice-diving-underwater-in-a-quarry-in-Canada.webp",4288,[],{},[455,456,457,458,459,460,461,462,463,464,465,466,467,468,469,470,471,472,473],"frozen","winter sport","window","canada","winter","Blue","Ice","Sports","scuba diving","cold","ice diving","exploration","diver","aquatic","water","winter sports","underwater","diving","scuba",[],{"text":476,"url":43,"target":27,"ariaLabel":28},"Explore our impact metrics",{"loggedUserInfo":-1},{"currentArticle":479,"isPreviewPage":344,"hasSupplementalData":344,"showCrossmarkWidget":13,"articleTemplate":628,"currentArticlePageMetaInfo":629,"xmlParsedArticleContent":753,"xmlParsingError":-1},{"id":480,"doi":481,"title":482,"acceptanceDate":483,"receptionDate":484,"publicationDate":485,"lastModifiedDate":486,"isPublished":13,"abstract":487,"researchTopic":28,"articleType":488,"stage":491,"keywords":493,"authors":510,"editors":552,"reviewers":563,"journal":582,"section":590,"impactMetrics":595,"volume":599,"articleVolume":600,"relatedArticles":601,"isPublishedV2":344,"contents":602,"laySummary":19,"files":603},366616,"10.3389/fpubh.2018.00149","Best Practices for Developing and Validating Scales for Health, Social, and Behavioral Research: A Primer",["Date","2018-05-02T06:14:36.000Z"],["Date","2018-02-26T21:56:55.000Z"],["Date","2018-06-11T00:00:00.000Z"],["Date","2026-07-22T03:24:25.520Z"],"Scale development and validation are critical to much of the work in the health, social, and behavioral sciences. However, the constellation of techniques required for scale development and evaluation can be onerous, jargon-filled, unfamiliar, and resource-intensive. Further, it is often not a part of graduate training.\nTherefore, our goal was to concisely review the process of scale development in as straightforward a manner as possible, both to facilitate the development of new, valid, and reliable scales and to help improve existing ones. To do this, we have created a primer for best practices for scale development in measuring complex phenomenon. \nThis is not a systematic review, but rather the amalgamation of technical literature and lessons learned from our experiences spent creating or adapting a number of scales over the past several decades. \nWe identified three phases that span nine steps. In the first phase, items are generated and the validity of their content is assessed. In the second phase, the scale is constructed. Steps in scale construction include pre-testing the questions, administering the survey, reducing the number of items, and understanding how many factors the scale captures. In the third phase, scale evaluation, the number of dimensions is tested, reliability is tested, and validity is assessed. We have also added examples of best practices to each step. \nIn sum, this primer will equip both scientists and practitioners to understand the ontology and methodology of scale development and validation, thereby facilitating the advancement of our understanding of a range of health, social, and behavioral outcomes",{"id":489,"name":490},27,"Review",{"id":492,"name":19},18,[494,495,496,497,498,499,500,501,502,503,504,505,506,507,508,509],"scale development","psychometric evaluation","Validation","Public health and nutrition","Content Validity","latent constructs","measurement theory","item development","Scale evaluation","Item reduction","Tests of dimensionality","tests of reliability","tests of validity","pretesting of questions","identification of domain","global health",[511,520,528,535,543],{"id":512,"firstName":513,"middleName":19,"lastName":514,"givenNames":515,"isCorresponding":344,"isProfilePublic":13,"userId":512,"email":-1,"affiliations":516},531529,"Godfred O.","Boateng","Godfred O. ",[517],{"organizationName":518,"countryName":519,"cityName":19,"stateName":19,"zipCode":19},"Department of Anthropology and Global Health, Northwestern University","United States",{"id":521,"firstName":522,"middleName":19,"lastName":523,"givenNames":524,"isCorresponding":344,"isProfilePublic":13,"userId":521,"email":-1,"affiliations":525},452315,"Torsten B.","Neilands","Torsten B. ",[526],{"organizationName":527,"countryName":519,"cityName":19,"stateName":19,"zipCode":19},"Division of Prevention Science, Department of Medicine, University of California, San Francisco",{"id":366,"firstName":529,"middleName":19,"lastName":530,"givenNames":531,"isCorresponding":344,"isProfilePublic":344,"userId":366,"email":-1,"affiliations":532},"Edward A.","Frongillo","Edward A. ",[533],{"organizationName":534,"countryName":519,"cityName":19,"stateName":19,"zipCode":19},"Department of Health Promotion, Education and Behavior, Arnold School of Public Health, University of South Carolina",{"id":366,"firstName":536,"middleName":19,"lastName":537,"givenNames":538,"isCorresponding":344,"isProfilePublic":344,"userId":366,"email":-1,"affiliations":539},"Hugo R.","Melgar-Quiñonez","Hugo R. ",[540],{"organizationName":541,"countryName":542,"cityName":19,"stateName":19,"zipCode":19},"Institute for Global Food Security, School of Human Nutrition, McGill University","Canada",{"id":544,"firstName":545,"middleName":19,"lastName":546,"givenNames":547,"isCorresponding":344,"isProfilePublic":13,"userId":544,"email":-1,"affiliations":548},349554,"Sera L.","Young","Sera L. ",[549,550],{"organizationName":518,"countryName":519,"cityName":19,"stateName":19,"zipCode":19},{"organizationName":551,"countryName":519,"cityName":19,"stateName":19,"zipCode":19},"Institute for Policy Research, Northwestern University",[553],{"id":554,"firstName":555,"middleName":556,"lastName":557,"givenNames":558,"isCorresponding":344,"isProfilePublic":13,"userId":554,"email":-1,"affiliations":559},36394,"Jimmy","Thomas","Efird","Jimmy  Thomas",[560],{"organizationName":561,"countryName":562,"cityName":19,"stateName":19,"zipCode":19},"The University of Newcastle","Australia",[564,573],{"id":565,"firstName":566,"middleName":19,"lastName":567,"givenNames":568,"isCorresponding":344,"isProfilePublic":13,"userId":565,"email":-1,"affiliations":569},227291,"Aida","Turrini","Aida ",[570],{"organizationName":571,"countryName":572,"cityName":19,"stateName":19,"zipCode":19},"Independent researcher","Italy",{"id":574,"firstName":575,"middleName":576,"lastName":577,"givenNames":578,"isCorresponding":344,"isProfilePublic":13,"userId":574,"email":-1,"affiliations":579},437670,"Mary","Evelyn","Northridge","Mary  Evelyn",[580],{"organizationName":581,"countryName":519,"cityName":19,"stateName":19,"zipCode":19},"Langone Medical Center, New York University",{"id":119,"slug":121,"name":120,"shortName":583,"electronicISSN":584,"field":585,"specialtyId":28,"journalSectionPaths":588},"Front. Public Health","2296-2565",{"id":586,"domainId":587},70,2,[589],{"section":590},{"id":591,"name":592,"slug":593,"specialtyId":594},633,"Epidemiology","epidemiology",390,{"views":596,"downloads":597,"citations":598},693886,130740,5246,6,"Volume 6 - 2018",[],{"titleHtml":19,"fullTextHtml":19,"menuHtml":19},[604,609,615,618,624],{"name":605,"fileServerPackageEntryId":19,"fileServerId":606,"fileServerVersionNumber":369,"type":607},"EPUB.epub","366616/epub",{"code":608,"name":608},"EPUB",{"name":610,"fileServerPackageEntryId":611,"fileServerId":612,"fileServerVersionNumber":369,"type":613},"fpubh-06-00149.pdf","fpubh-06-00149/fpubh-06-00149.pdf","366616/pubmed-zip",{"code":614,"name":614},"PDF",{"name":610,"fileServerPackageEntryId":19,"fileServerId":616,"fileServerVersionNumber":369,"type":617},"366616/publishers-proof/pdf",{"code":614,"name":614},{"name":619,"fileServerPackageEntryId":620,"fileServerId":612,"fileServerVersionNumber":369,"type":621},"fpubh-06-00149.xml","fpubh-06-00149/fpubh-06-00149.xml",{"code":622,"name":623},"NLM_XML","XML",{"name":625,"fileServerPackageEntryId":19,"fileServerId":626,"fileServerVersionNumber":369,"type":627},"Provisional PDF.pdf","366616/provisional-pdf",{"code":614,"name":614},"v4",{"title":630,"link":631,"meta":635,"script":742},"Frontiers | Best Practices for Developing and Validating Scales for Health, Social, and Behavioral Research: A Primer",[632],{"rel":633,"href":634},"canonical","https://www.frontiersin.org/journals/public-health/articles/10.3389/fpubh.2018.00149/full",[636,639,642,644,647,651,654,658,661,664,667,669,671,673,675,677,680,683,685,688,691,693,696,699,702,705,708,712,716,719,722,725,728,731,734,737,739],{"hid":637,"property":637,"name":637,"content":638},"description","Scale development and validation are critical to much of the work in the health, social, and behavioral sciences. However, the constellation of techniques re...",{"hid":640,"property":640,"name":641,"content":630},"og:title","title",{"hid":643,"property":643,"name":637,"content":638},"og:description",{"hid":645,"name":645,"content":646},"keywords","scale development,psychometric evaluation,Validation,Public health and nutrition,Content Validity,latent constructs,measurement theory,item development,Scale evaluation,Item reduction,Tests of dimensionality,tests of reliability,tests of validity,pretesting of questions,identification of domain,global health",{"hid":648,"property":648,"name":649,"content":650},"og:site_name","site_name","Frontiers",{"hid":652,"property":652,"name":362,"content":653},"og:image","https://www.frontiersin.org/api/ipx/w=1200&f=png/https://www.frontiersin.org/files/Articles/366616/fpubh-06-00149-HTML/image_m/fpubh-06-00149-g001.jpg",{"hid":655,"property":655,"name":656,"content":657},"og:type","type","article",{"hid":659,"property":659,"name":660,"content":634},"og:url","url",{"hid":662,"name":662,"content":663},"twitter:card","summary_large_image",{"hid":665,"name":665,"content":666},"citation_volume","6",{"hid":668,"name":668,"content":120},"citation_journal_title",{"hid":670,"name":670,"content":650},"citation_publisher",{"hid":672,"name":672,"content":583},"citation_journal_abbrev",{"hid":674,"name":674,"content":584},"citation_issn",{"hid":676,"name":676,"content":481},"citation_doi",{"hid":678,"name":678,"content":679},"citation_firstpage","366616",{"hid":681,"name":681,"content":682},"citation_language","English",{"hid":684,"name":684,"content":482},"citation_title",{"hid":686,"name":686,"content":687},"citation_keywords","scale development; psychometric evaluation; Validation; Public health and nutrition; Content Validity; latent constructs; measurement theory; item development; Scale evaluation; Item reduction; Tests of dimensionality; tests of reliability; tests of validity; pretesting of questions; identification of domain; global health",{"hid":689,"name":689,"content":690},"citation_abstract","Scale development and validation are critical to much of the work in the health, social, and behavioral sciences. However, the constellation of techniques required for scale development and evaluation can be onerous, jargon-filled, unfamiliar, and resource-intensive. Further, it is often not a part of graduate training.Therefore, our goal was to concisely review the process of scale development in as straightforward a manner as possible, both to facilitate the development of new, valid, and reliable scales and to help improve existing ones. To do this, we have created a primer for best practices for scale development in measuring complex phenomenon. This is not a systematic review, but rather the amalgamation of technical literature and lessons learned from our experiences spent creating or adapting a number of scales over the past several decades. We identified three phases that span nine steps. In the first phase, items are generated and the validity of their content is assessed. In the second phase, the scale is constructed. Steps in scale construction include pre-testing the questions, administering the survey, reducing the number of items, and understanding how many factors the scale captures. In the third phase, scale evaluation, the number of dimensions is tested, reliability is tested, and validity is assessed. We have also added examples of best practices to each step. In sum, this primer will equip both scientists and practitioners to understand the ontology and methodology of scale development and validation, thereby facilitating the advancement of our understanding of a range of health, social, and behavioral outcomes",{"hid":692,"name":692,"content":490},"citation_article_type",{"hid":694,"name":694,"content":695},"citation_pdf_url","https://www.frontiersin.org/journals/public-health/articles/10.3389/fpubh.2018.00149/pdf",{"hid":697,"name":697,"content":698},"citation_xml_url","https://www.frontiersin.org/journals/public-health/articles/10.3389/fpubh.2018.00149/xml",{"hid":700,"name":700,"content":701},"citation_fulltext_world_readable","yes",{"hid":703,"name":703,"content":704},"citation_online_date","2018/05/02",{"hid":706,"name":706,"content":707},"citation_publication_date","2018/06/11",{"hid":709,"name":710,"content":711},"citation_author_0","citation_author","Boateng, Godfred O. ",{"hid":713,"name":714,"content":715},"citation_author_institution_0","citation_author_institution","Department of Anthropology and Global Health, Northwestern University, United States",{"hid":717,"name":710,"content":718},"citation_author_1","Neilands, Torsten B. ",{"hid":720,"name":714,"content":721},"citation_author_institution_1","Division of Prevention Science, Department of Medicine, University of California, San Francisco, United States",{"hid":723,"name":710,"content":724},"citation_author_2","Frongillo, Edward A. ",{"hid":726,"name":714,"content":727},"citation_author_institution_2","Department of Health Promotion, Education and Behavior, Arnold School of Public Health, University of South Carolina, United States",{"hid":729,"name":710,"content":730},"citation_author_3","Melgar-Quiñonez, Hugo R. ",{"hid":732,"name":714,"content":733},"citation_author_institution_3","Institute for Global Food Security, School of Human Nutrition, McGill University, Canada",{"hid":735,"name":710,"content":736},"citation_author_4","Young, Sera L. ",{"hid":738,"name":714,"content":715},"citation_author_institution_4",{"hid":740,"name":740,"content":741},"dc.identifier","doi:10.3389/fpubh.2018.00149",[743,746,749,751],{"src":744,"body":13,"type":745,"async":13},"https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?features=es6","text/javascript",{"innerHTML":747,"type":748},"MathJax.Hub.Config({\"CommonHTML\":{linebreaks:{automatic:true,width:\"container\"}}});","text/x-mathjax-config",{"src":750,"body":13,"type":745,"async":13},"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-MML-AM_CHTML",{"src":752,"body":13,"type":745,"async":13},"https://crossmark-cdn.crossref.org/widget/v2.0/widget.js",{"journal":754,"doi":481,"articleType":490,"title":756,"authors":758,"onBehalfOf":19,"affiliations":775,"authorNotes":790,"publicationDate":824,"acceptedDate":825,"receivedDate":826,"correctedDate":19,"retractedDate":19,"volume":599,"elocationId":827,"permissions":828,"keywords":848,"relatedArticles":869,"abstractContent":870,"bodyContent":878,"appendixContent":5397,"statements":5398,"referenceLists":6009,"references":17183,"otherBackSections":27169,"figures":27170,"toc":28757,"correspondingAuthors":28773},{"title":120,"abbreviation":583,"issn":584,"publisherName":755},"Frontiers Media S.A.",[757],{"#text":482},[759,762,765,768,771],{"surname":514,"givenNames":513,"suffix":19,"affiliationsIndexes":760,"isCorresponding":13,"equalContrib":344,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":761,"onBehalfOf":19},[369],"http://loop.frontiersin.org/people/531529/overview",{"surname":523,"givenNames":522,"suffix":19,"affiliationsIndexes":763,"isCorresponding":344,"equalContrib":344,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":764,"onBehalfOf":19},[587],"http://loop.frontiersin.org/people/452315/overview",{"surname":530,"givenNames":529,"suffix":19,"affiliationsIndexes":766,"isCorresponding":344,"equalContrib":344,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[767],3,{"surname":537,"givenNames":536,"suffix":19,"affiliationsIndexes":769,"isCorresponding":344,"equalContrib":344,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":19,"onBehalfOf":19},[770],4,{"surname":546,"givenNames":545,"suffix":19,"affiliationsIndexes":772,"isCorresponding":344,"equalContrib":344,"hierarchySymbol":19,"footnoteSymbol":19,"loopUrl":774,"onBehalfOf":19},[369,773],5,"http://loop.frontiersin.org/people/349554/overview",[776,779,782,785,788],{"index":369,"baseText":19,"institution":518,"country":519,"address":777,"textContent":778},"Evanston, IL","Department of Anthropology and Global Health, Northwestern University, Evanston, IL, United States",{"index":587,"baseText":19,"institution":527,"country":519,"address":780,"textContent":781},"San Francisco, CA","Division of Prevention Science, Department of Medicine, University of California, San Francisco, San Francisco, CA, United States",{"index":767,"baseText":19,"institution":534,"country":519,"address":783,"textContent":784},"Columbia, SC","Department of Health Promotion, Education and Behavior, Arnold School of Public Health, University of South Carolina, Columbia, SC, United States",{"index":770,"baseText":19,"institution":541,"country":542,"address":786,"textContent":787},"Montreal, QC","Institute for Global Food Security, School of Human Nutrition, McGill University, Montreal, QC, Canada",{"index":773,"baseText":19,"institution":551,"country":519,"address":777,"textContent":789},"Institute for Policy Research, Northwestern University, Evanston, IL, United States",{"editedBy":791,"editedByContent":794,"reviewedBy":803,"reviewedByContent":806,"approvedBy":813,"approvedByContent":814,"correspondence":815,"equalContribution":816,"presentAddress":19,"other":817},[792],{"textContent":793},"Edited by: Jimmy Thomas Efird, University of Newcastle, Australia",[795,797,801],{"#text":796},"\n          ",{"p":798},[799],{"#text":800}," Jimmy Thomas Efird, University of Newcastle, Australia",{"#text":802},"\n        ",[804],{"textContent":805},"Reviewed by: Aida Turrini, Consiglio per la Ricerca in Agricoltura e L'analisi Dell'Economia Agraria (CREA), Italy; Mary Evelyn Northridge, New York University, United States",[807,808,812],{"#text":796},{"p":809},[810],{"#text":811}," Aida Turrini, Consiglio per la Ricerca in Agricoltura e L'analisi Dell'Economia Agraria (CREA), Italy; Mary Evelyn Northridge, New York University, United States",{"#text":802},[],[],"*Correspondence: Godfred O. Boateng Z29kZnJlZC5ib2F0ZW5nQG5vcnRod2VzdGVybi5lZHU=",[],[818,819,823],{"#text":796},{"p":820},[821],{"#text":822},"This article was submitted to Epidemiology, a section of the journal Frontiers in Public Health",{"#text":802},"2018-06-11","2018-05-02","2018-02-26",149,{"copyrightStatement":829,"copyrightYear":830,"copyrightHolder":831,"licenseUrl":832,"licenseText":833},"Copyright © 2018 Boateng, Neilands, Frongillo, Melgar-Quiñonez and Young.",2018,"Boateng, Neilands, Frongillo, Melgar-Quiñonez and Young","http://creativecommons.org/licenses/by/4.0/",[834,835,847],{"#text":796},{"p":836},[837,839,845],{"#text":838},"This is an open-access article distributed under the terms of the ",{"ext-link":840,":@":843},[841],{"#text":842},"Creative Commons Attribution License (CC BY)",{"@_ext-link-type":844,"@_xlink:href":832},"uri",{"#text":846},". The use, distribution or reproduction in other forums is permitted, provided the original author(s) and the copyright owner are credited and that the original publication in this journal is cited, in accordance with accepted academic practice. No use, distribution or reproduction is permitted which does not comply with these terms.",{"#text":802},[849,851,853,856,859,862,865,867],[850],{"#text":494},[852],{"#text":495},[854],{"#text":855},"content validity",[857],{"#text":858},"item reduction",[860],{"#text":861},"factor analysis",[863],{"#text":864},"tests of dimensionality",[866],{"#text":505},[868],{"#text":506},[],[871,872,876],{"#text":802},{"p":873},[874],{"#text":875},"Scale development and validation are critical to much of the work in the health, social, and behavioral sciences. However, the constellation of techniques required for scale development and evaluation can be onerous, jargon-filled, unfamiliar, and resource-intensive. Further, it is often not a part of graduate training. Therefore, our goal was to concisely review the process of scale development in as straightforward a manner as possible, both to facilitate the development of new, valid, and reliable scales, and to help improve existing ones. To do this, we have created a primer for best practices for scale development in measuring complex phenomena. This is not a systematic review, but rather the amalgamation of technical literature and lessons learned from our experiences spent creating or adapting a number of scales over the past several decades. We identified three phases that span nine steps. In the first phase, items are generated and the validity of their content is assessed. In the second phase, the scale is constructed. Steps in scale construction include pre-testing the questions, administering the survey, reducing the number of items, and understanding how many factors the scale captures. In the third phase, scale evaluation, the number of dimensions is tested, reliability is tested, and validity is assessed. We have also added examples of best practices to each step. In sum, this primer will equip both scientists and practitioners to understand the ontology and methodology of scale development and validation, thereby facilitating the advancement of our understanding of a range of health, social, and behavioral outcomes.",{"#text":877},"\n      ",[879,881,970,971,2513,2514,3107,3108,4101,4102,5302,5303,5364,5365,5395],{"#text":880},"\n    ",{"sec":882,":@":967,"anchorId":969},[883,884,888,889,902,903,907,908,942,943,961,962,966],{"#text":877},{"title":885},[886],{"#text":887},"Introduction",{"#text":877},{"p":890},[891,893,900],{"#text":892},"Scales are a manifestation of latent constructs; they measure behaviors, attitudes, and hypothetical scenarios we expect to exist as a result of our theoretical understanding of the world, but cannot assess directly (",{"xref":894,":@":897},[895],{"#text":896},"1",{"@_ref-type":898,"@_rid":899},"bibr","B1",{"#text":901},"). Scales are typically used to capture a behavior, a feeling, or an action that cannot be captured in a single variable or item. The use of multiple items to measure an underlying latent construct can additionally account for, and isolate, item-specific measurement error, which",{"#text":877},{"p":904},[905],{"#text":906},"leads to more accurate research findings. Thousands of scales have been developed that can measure a range of social, psychological, and health behaviors and experiences.",{"#text":877},{"p":909},[910,912,916,918,924,926,932,934,940],{"#text":911},"As science advances and novel research questions are put forth, new scales become necessary. Scale development is not, however, an obvious or a straightforward endeavor. There are many steps to scale development, there is significant jargon within these techniques, the work can be costly and time consuming, and complex statistical analysis is often required. Further, many health and behavioral science degrees do not include training on scale development. Despite the availability of a large amount of technical literature on scale theory and development (",{"xref":913,":@":915},[914],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":917},"–",{"xref":919,":@":922},[920],{"#text":921},"7",{"@_ref-type":898,"@_rid":923},"B7",{"#text":925},"), there are a number of incomplete scales used to measure mental, physical, and behavioral attributes that are fundamental to our scientific inquiry (",{"xref":927,":@":930},[928],{"#text":929},"8",{"@_ref-type":898,"@_rid":931},"B8",{"#text":933},", ",{"xref":935,":@":938},[936],{"#text":937},"9",{"@_ref-type":898,"@_rid":939},"B9",{"#text":941},").",{"#text":877},{"p":944},[945,947,953,954,960],{"#text":946},"Therefore, our goal is to describe the process for scale development in as straightforward a manner as possible, both to facilitate the development of new, valid, and reliable scales, and to help improve existing ones. To do this, we have created a primer for best practices for scale development. We anticipate this primer will be broadly applicable across many disciplines, especially for health, social, and behavioral sciences. This is not a systematic review, but rather the amalgamation of technical literature and lessons learned from our experiences spent creating or adapting a number of scales related to multiple disciplines (",{"xref":948,":@":951},[949],{"#text":950},"10",{"@_ref-type":898,"@_rid":952},"B10",{"#text":917},{"xref":955,":@":958},[956],{"#text":957},"23",{"@_ref-type":898,"@_rid":959},"B23",{"#text":941},{"#text":877},{"p":963},[964],{"#text":965},"First, we provide an overview of each of the nine steps. Then, within each step, we define key concepts, describe the tasks required to achieve that step, share common pitfalls, and draw on examples in the health, social, and behavioral sciences to recommend best practices. We have tried to keep the material as straightforward as possible; references to the body of technical work have been the foundation of this primer.",{"#text":880},{"@_sec-type":968,"@_id":969},"intro","s1",{"#text":880},{"sec":972,":@":2511,"anchorId":2512},[973,974,978,979,998,999,1024,1025,1029,1030,2510],{"#text":877},{"title":975},[976],{"#text":977},"Scale development overview",{"#text":877},{"p":980},[981,983,989,991,997],{"#text":982},"There are three phases to creating a rigorous scale—item development, scale development, and scale evaluation (",{"xref":984,":@":987},[985],{"#text":986},"24",{"@_ref-type":898,"@_rid":988},"B24",{"#text":990},"); these can be further broken down into nine steps (Figure ",{"xref":992,":@":994},[993],{"#text":896},{"@_ref-type":995,"@_rid":996},"fig","F1",{"#text":941},{"#text":877},{"fig":1000,":@":1022},[1001,1002,1006,1007,1015,1016,1021],{"#text":802},{"label":1003},[1004],{"#text":1005},"Figure 1",{"#text":802},{"caption":1008},[1009,1010,1014],{"#text":796},{"p":1011},[1012],{"#text":1013},"An overview of the three phases and nine steps of scale development and validation.",{"#text":802},{"#text":802},{"graphic":1017,":@":1018},[],{"@_xmlns:xlink":1019,"@_xlink:href":1020},"http://www.w3.org/1999/xlink","fpubh-06-00149-g0001.tif",{"#text":877},{"@_id":996,"@_position":1023},"float",{"#text":877},{"p":1026},[1027],{"#text":1028},"Item development, i.e., coming up with the initial set of questions for an eventual scale, is composed of: (1) identification of the domain(s) and item generation, and (2) consideration of content validity. The second phase, scale development, i.e., turning individual items into a harmonious and measuring construct, consists of (3) pre-testing questions, (4) sampling and survey administration, (5) item reduction, and (6) extraction of latent factors. The last phase, scale evaluation, requires: (7) tests of dimensionality, (8) tests of reliability, and (9) tests of validity.",{"#text":877},{"table-wrap":1031,":@":2508},[1032,1033,1037,1038,1046,1047,2507],{"#text":802},{"label":1034},[1035],{"#text":1036},"Table 1",{"#text":802},{"caption":1039},[1040,1041,1045],{"#text":796},{"p":1042},[1043],{"#text":1044},"The three phases and nine steps of scale development and validation.",{"#text":802},{"#text":802},{"table":1048,":@":2504},[1049,1050,1102,1103,2503],{"#text":796},{"thead":1051},[1052,1054,1101],{"#text":1053},"\n            ",{"tr":1055},[1056,1058,1070,1071,1080,1081,1090,1091,1100],{"#text":1057},"\n              ",{"th":1059,":@":1067},[1060,1062,1066],{"#text":1061},"\n                ",{"bold":1063},[1064],{"#text":1065},"Activity",{"#text":1057},{"@_valign":1068,"@_align":1069},"top","left",{"#text":1057},{"th":1072,":@":1079},[1073,1074,1078],{"#text":1061},{"bold":1075},[1076],{"#text":1077},"Purpose",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"th":1082,":@":1089},[1083,1084,1088],{"#text":1061},{"bold":1085},[1086],{"#text":1087},"How to explore or estimate?",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"th":1092,":@":1099},[1093,1094,1098],{"#text":1061},{"bold":1095},[1096],{"#text":1097},"References",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":796},{"#text":796},{"tbody":1104},[1105,1106,1120,1121,1144,1145,1213,1214,1270,1271,1296,1297,1356,1357,1395,1396,1409,1410,1433,1434,1474,1475,1499,1500,1540,1541,1588,1589,1619,1620,1644,1645,1695,1696,1736,1737,1785,1786,1826,1827,1867,1868,1892,1893,1943,1944,1957,1958,1981,1982,2036,2037,2074,2075,2099,2100,2144,2145,2195,2196,2220,2221,2234,2235,2278,2279,2310,2311,2325,2326,2371,2372,2413,2414,2456,2457,2502],{"#text":1053},{"tr":1107},[1108,1109,1119],{"#text":1057},{"td":1110,":@":1117},[1111,1112,1116],{"#text":1061},{"bold":1113},[1114],{"#text":1115},"PHASE 1: ITEM DEVELOPMENT",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":770,"@_style":1118},"background-color:#bbbdc0",{"#text":1053},{"#text":1053},{"tr":1122},[1123,1124,1133,1134,1143],{"#text":1057},{"td":1125,":@":1132},[1126,1127,1131],{"#text":1061},{"inline-graphic":1128,":@":1129},[],{"@_xlink:href":1130},"fpubh-06-00149-i0001.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1135,":@":1142},[1136,1137,1141],{"#text":1061},{"bold":1138},[1139],{"#text":1140},"Step 1: Identification of Domain and Item Generation: Selecting Which Items to Ask",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"#text":1053},{"tr":1146},[1147,1148,1153,1154,1159,1160,1185,1186,1212],{"#text":1057},{"td":1149,":@":1152},[1150],{"#text":1151},"Domain identification",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1155,":@":1158},[1156],{"#text":1157},"To specify the boundaries of the domain and facilitate item generation",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1161,":@":1184},[1162,1164,1166,1168,1170,1172,1174,1176,1180,1182],{"#text":1163},"1.1 Specify the purpose of the domain",{"break":1165},[],{"#text":1167}," 1.2 Confirm that there are no existing instruments",{"break":1169},[],{"#text":1171},"1.3 Describe the domain and provide preliminary conceptual definition",{"break":1173},[],{"#text":1175}," 1.4 Specify the dimensions of the domain if they exist ",{"italic":1177},[1178],{"#text":1179},"a priori",{"break":1181},[],{"#text":1183},"1.5 Define each dimension",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1187,":@":1211},[1188,1190,1194,1195,1201,1203,1209],{"#text":1189},"(",{"xref":1191,":@":1193},[1192],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":917},{"xref":1196,":@":1199},[1197],{"#text":1198},"4",{"@_ref-type":898,"@_rid":1200},"B4",{"#text":1202},"), (",{"xref":1204,":@":1207},[1205],{"#text":1206},"25",{"@_ref-type":898,"@_rid":1208},"B25",{"#text":1210},")",{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1215},[1216,1217,1222,1223,1228,1229,1238,1239,1269],{"#text":1057},{"td":1218,":@":1221},[1219],{"#text":1220},"Item generation",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1224,":@":1227},[1225],{"#text":1226},"To identify appropriate questions that fit the identified domain",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1230,":@":1237},[1231,1233,1235],{"#text":1232},"1.6 Deductive methods: literature review and assessment of existing scales",{"break":1234},[],{"#text":1236},"1.7 Inductive methods: exploratory research methodologies including focus group discussions and interviews",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1240,":@":1268},[1241,1242,1248,1249,1255,1256,1260,1261,1267],{"#text":1189},{"xref":1243,":@":1246},[1244],{"#text":1245},"2",{"@_ref-type":898,"@_rid":1247},"B2",{"#text":917},{"xref":1250,":@":1253},[1251],{"#text":1252},"5",{"@_ref-type":898,"@_rid":1254},"B5",{"#text":1202},{"xref":1257,":@":1259},[1258],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":917},{"xref":1262,":@":1265},[1263],{"#text":1264},"41",{"@_ref-type":898,"@_rid":1266},"B41",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1272,":@":1294},[1273,1274,1283,1284,1293],{"#text":1057},{"td":1275,":@":1282},[1276,1277,1281],{"#text":1061},{"inline-graphic":1278,":@":1279},[],{"@_xlink:href":1280},"fpubh-06-00149-i0002.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1285,":@":1292},[1286,1287,1291],{"#text":1061},{"bold":1288},[1289],{"#text":1290},"Step 2: Content Validity: Assessing if the Items Adequately Measure the Domain of Interest",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"@_style":1295},"border-top: thin solid #000000;",{"#text":1053},{"tr":1298},[1299,1300,1305,1306,1311,1312,1321,1322,1355],{"#text":1057},{"td":1301,":@":1304},[1302],{"#text":1303},"Evaluation by experts",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1307,":@":1310},[1308],{"#text":1309},"To evaluate each of the items constituting the domain for content relevance, representativeness, and technical quality",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1313,":@":1320},[1314,1316,1318],{"#text":1315},"2.1 Quantify assessments of 5-7 expert judges using formalized scaling and statistical procedures including content validity ratio, content validity index, or Cohen's coefficient alpha",{"break":1317},[],{"#text":1319},"2.2 Conduct Delphi method with expert judges",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1323,":@":1354},[1324,1325,1329,1330,1334,1335,1339,1340,1346,1347,1353],{"#text":1189},{"xref":1326,":@":1328},[1327],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":917},{"xref":1331,":@":1333},[1332],{"#text":1252},{"@_ref-type":898,"@_rid":1254},{"#text":1202},{"xref":1336,":@":1338},[1337],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":933},{"xref":1341,":@":1344},[1342],{"#text":1343},"42",{"@_ref-type":898,"@_rid":1345},"B42",{"#text":917},{"xref":1348,":@":1351},[1349],{"#text":1350},"48",{"@_ref-type":898,"@_rid":1352},"B48",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1358},[1359,1360,1365,1366,1371,1372,1377,1378,1394],{"#text":1057},{"td":1361,":@":1364},[1362],{"#text":1363},"Evaluation by target population",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1367,":@":1370},[1368],{"#text":1369},"To evaluate each item constituting the domain for representativeness of actual experience from target population",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1373,":@":1376},[1374],{"#text":1375},"2.3 Conduct cognitive interviews with end users of scale items to evaluate face validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1379,":@":1393},[1380,1381,1387,1388,1392],{"#text":1189},{"xref":1382,":@":1385},[1383],{"#text":1384},"20",{"@_ref-type":898,"@_rid":1386},"B20",{"#text":933},{"xref":1389,":@":1391},[1390],{"#text":1206},{"@_ref-type":898,"@_rid":1208},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1397},[1398,1399,1408],{"#text":1057},{"td":1400,":@":1407},[1401,1402,1406],{"#text":1061},{"bold":1403},[1404],{"#text":1405},"PHASE 2: SCALE DEVELOPMENT",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":770,"@_style":1118},{"#text":1053},{"#text":1053},{"tr":1411},[1412,1413,1422,1423,1432],{"#text":1057},{"td":1414,":@":1421},[1415,1416,1420],{"#text":1061},{"inline-graphic":1417,":@":1418},[],{"@_xlink:href":1419},"fpubh-06-00149-i0003.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1424,":@":1431},[1425,1426,1430],{"#text":1061},{"bold":1427},[1428],{"#text":1429},"Step 3: Pre-testing Questions: Ensuring the Questions and Answers Are Meaningful",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"#text":1053},{"tr":1435},[1436,1437,1442,1443,1448,1449,1454,1455,1473],{"#text":1057},{"td":1438,":@":1441},[1439],{"#text":1440},"Cognitive interviews",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1444,":@":1447},[1445],{"#text":1446},"To assess the extent to which questions reflect the domain of interest and that answers produce valid measurements",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1450,":@":1453},[1451],{"#text":1452},"3.1 Administer draft questions to 5–15 interviewees in 2–3 rounds while allowing respondents to verbalize the mental process entailed in providing answers",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1456,":@":1472},[1457,1458,1464,1465,1471],{"#text":1189},{"xref":1459,":@":1462},[1460],{"#text":1461},"49",{"@_ref-type":898,"@_rid":1463},"B49",{"#text":917},{"xref":1466,":@":1469},[1467],{"#text":1468},"54",{"@_ref-type":898,"@_rid":1470},"B54",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1476,":@":1498},[1477,1478,1487,1488,1497],{"#text":1057},{"td":1479,":@":1486},[1480,1481,1485],{"#text":1061},{"inline-graphic":1482,":@":1483},[],{"@_xlink:href":1484},"fpubh-06-00149-i0004.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1489,":@":1496},[1490,1491,1495],{"#text":1061},{"bold":1492},[1493],{"#text":1494},"Step 4: Survey Administration and Sample Size: Gathering Enough Data from the Right People",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"@_style":1295},{"#text":1053},{"tr":1501},[1502,1503,1508,1509,1514,1515,1520,1521,1539],{"#text":1057},{"td":1504,":@":1507},[1505],{"#text":1506},"Survey administration",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1510,":@":1513},[1511],{"#text":1512},"To collect data with minimum measurement errors",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1516,":@":1519},[1517],{"#text":1518},"4.1 Administer potential scale items on a sample that reflects range of target population using paper or device",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1522,":@":1538},[1523,1524,1530,1531,1537],{"#text":1189},{"xref":1525,":@":1528},[1526],{"#text":1527},"55",{"@_ref-type":898,"@_rid":1529},"B55",{"#text":917},{"xref":1532,":@":1535},[1533],{"#text":1534},"58",{"@_ref-type":898,"@_rid":1536},"B58",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1542},[1543,1544,1549,1550,1555,1556,1561,1562,1587],{"#text":1057},{"td":1545,":@":1548},[1546],{"#text":1547},"Establishing the sample size",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1551,":@":1554},[1552],{"#text":1553},"To ensure the availability of sufficient data for scale development",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1557,":@":1560},[1558],{"#text":1559},"4.2 Recommended sample size is 10 respondents per survey item and/or 200-300 observations",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1563,":@":1586},[1564,1565,1571,1572,1578,1579,1585],{"#text":1189},{"xref":1566,":@":1569},[1567],{"#text":1568},"29",{"@_ref-type":898,"@_rid":1570},"B29",{"#text":933},{"xref":1573,":@":1576},[1574],{"#text":1575},"59",{"@_ref-type":898,"@_rid":1577},"B59",{"#text":917},{"xref":1580,":@":1583},[1581],{"#text":1582},"65",{"@_ref-type":898,"@_rid":1584},"B65",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1590},[1591,1592,1597,1598,1603,1604,1613,1614,1618],{"#text":1057},{"td":1593,":@":1596},[1594],{"#text":1595},"Determining the type of data to use",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1599,":@":1602},[1600],{"#text":1601},"To ensure the availability of data for scale development and validation",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1605,":@":1612},[1606,1608,1610],{"#text":1607},"4.3 Use cross-sectional data for exploratory factor analysis",{"break":1609},[],{"#text":1611},"4.4 Use data from a second time point, at least 3 months later in a longitudinal dataset, or an independent sample for test of dimensionality (Step 7)",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1615,":@":1617},[1616],{"#text":917},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1621,":@":1643},[1622,1623,1632,1633,1642],{"#text":1057},{"td":1624,":@":1631},[1625,1626,1630],{"#text":1061},{"inline-graphic":1627,":@":1628},[],{"@_xlink:href":1629},"fpubh-06-00149-i0005.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1634,":@":1641},[1635,1636,1640],{"#text":1061},{"bold":1637},[1638],{"#text":1639},"Step 5: Item Reduction: Ensuring Your Scale Is Parsimonious",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"@_style":1295},{"#text":1053},{"tr":1646},[1647,1648,1653,1654,1659,1660,1665,1666,1694],{"#text":1057},{"td":1649,":@":1652},[1650],{"#text":1651},"Item difficulty index",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1655,":@":1658},[1656],{"#text":1657},"To determine the proportion of correct answers given per item (CTT) To determine the probability of a particular examinee correctly answering a given item (IRT)",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1661,":@":1664},[1662],{"#text":1663},"5.1 Proportion can be calculated for CTT and item difficulty parameter estimated for IRT using statistical packages",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1667,":@":1693},[1668,1669,1673,1674,1678,1679,1685,1686,1692],{"#text":1189},{"xref":1670,":@":1672},[1671],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":1675,":@":1677},[1676],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":1680,":@":1683},[1681],{"#text":1682},"66",{"@_ref-type":898,"@_rid":1684},"B66",{"#text":917},{"xref":1687,":@":1690},[1688],{"#text":1689},"68",{"@_ref-type":898,"@_rid":1691},"B68",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1697},[1698,1699,1704,1705,1710,1711,1716,1717,1735],{"#text":1057},{"td":1700,":@":1703},[1701],{"#text":1702},"Item discrimination test",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1706,":@":1709},[1707],{"#text":1708},"To determine the degree to which an item or set of test questions are measuring a unitary attribute (CTT) To determine how steeply the probability of correct response changes as ability increases (IRT)",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1712,":@":1715},[1713],{"#text":1714},"5.2 Estimate biserial correlations or item discrimination parameter using statistical packages",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1718,":@":1734},[1719,1720,1726,1727,1733],{"#text":1189},{"xref":1721,":@":1724},[1722],{"#text":1723},"69",{"@_ref-type":898,"@_rid":1725},"B69",{"#text":917},{"xref":1728,":@":1731},[1729],{"#text":1730},"75",{"@_ref-type":898,"@_rid":1732},"B75",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1738},[1739,1740,1745,1746,1751,1752,1757,1758,1784],{"#text":1057},{"td":1741,":@":1744},[1742],{"#text":1743},"Inter-item and item-total correlations",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1747,":@":1750},[1748],{"#text":1749},"To determine the correlations between scale items, as well as the correlations between each item and sum score of scale items",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1753,":@":1756},[1754],{"#text":1755},"5.3 Estimate inter-item/item communalities, item-total, and adjusted item-total correlations using statistical packages",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1759,":@":1783},[1760,1761,1765,1766,1770,1771,1775,1776,1782],{"#text":1189},{"xref":1762,":@":1764},[1763],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":1767,":@":1769},[1768],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":1772,":@":1774},[1773],{"#text":1689},{"@_ref-type":898,"@_rid":1691},{"#text":933},{"xref":1777,":@":1780},[1778],{"#text":1779},"76",{"@_ref-type":898,"@_rid":1781},"B76",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1787},[1788,1789,1794,1795,1800,1801,1806,1807,1825],{"#text":1057},{"td":1790,":@":1793},[1791],{"#text":1792},"Distractor efficiency analysis",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1796,":@":1799},[1797],{"#text":1798},"To determine the distribution of incorrect options and how they contribute to the quality of items",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1802,":@":1805},[1803],{"#text":1804},"5.4 Estimate distractor analysis using statistical packages",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1808,":@":1824},[1809,1810,1816,1817,1823],{"#text":1189},{"xref":1811,":@":1814},[1812],{"#text":1813},"77",{"@_ref-type":898,"@_rid":1815},"B77",{"#text":917},{"xref":1818,":@":1821},[1819],{"#text":1820},"80",{"@_ref-type":898,"@_rid":1822},"B80",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1828},[1829,1830,1835,1836,1841,1842,1847,1848,1866],{"#text":1057},{"td":1831,":@":1834},[1832],{"#text":1833},"Deleting or imputing missing cases",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1837,":@":1840},[1838],{"#text":1839},"To ensure the availability of complete cases for scale development",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1843,":@":1846},[1844],{"#text":1845},"5.5 Delete items with many cases that are permanently missing, or use multiple imputation or full information maximum likelihood for imputation of data",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1849,":@":1865},[1850,1851,1857,1858,1864],{"#text":1189},{"xref":1852,":@":1855},[1853],{"#text":1854},"81",{"@_ref-type":898,"@_rid":1856},"B81",{"#text":917},{"xref":1859,":@":1862},[1860],{"#text":1861},"84",{"@_ref-type":898,"@_rid":1863},"B84",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1869,":@":1891},[1870,1871,1880,1881,1890],{"#text":1057},{"td":1872,":@":1879},[1873,1874,1878],{"#text":1061},{"inline-graphic":1875,":@":1876},[],{"@_xlink:href":1877},"fpubh-06-00149-i0006.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1882,":@":1889},[1883,1884,1888],{"#text":1061},{"bold":1885},[1886],{"#text":1887},"Step 6: Extraction of Factors: Exploring the Number of Latent Constructs that Fit Your Observed Data",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"@_style":1295},{"#text":1053},{"tr":1894},[1895,1896,1901,1902,1907,1908,1913,1914,1942],{"#text":1057},{"td":1897,":@":1900},[1898],{"#text":1899},"Factor analysis",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1903,":@":1906},[1904],{"#text":1905},"To determine the optimal number of factors or domains that fit a set of items",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1909,":@":1912},[1910],{"#text":1911},"6.1 Use scree plots, exploratory factor analysis, parallel analysis, minimum average partial procedure, and/or the Hull method",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1915,":@":1941},[1916,1917,1921,1922,1926,1927,1933,1934,1940],{"#text":1189},{"xref":1918,":@":1920},[1919],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":917},{"xref":1923,":@":1925},[1924],{"#text":1198},{"@_ref-type":898,"@_rid":1200},{"#text":1202},{"xref":1928,":@":1931},[1929],{"#text":1930},"85",{"@_ref-type":898,"@_rid":1932},"B85",{"#text":917},{"xref":1935,":@":1938},[1936],{"#text":1937},"90",{"@_ref-type":898,"@_rid":1939},"B90",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":1945},[1946,1947,1956],{"#text":1057},{"td":1948,":@":1955},[1949,1950,1954],{"#text":1061},{"bold":1951},[1952],{"#text":1953},"PHASE 3: SCALE EVALUTION",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":770,"@_style":1118},{"#text":1053},{"#text":1053},{"tr":1959},[1960,1961,1970,1971,1980],{"#text":1057},{"td":1962,":@":1969},[1963,1964,1968],{"#text":1061},{"inline-graphic":1965,":@":1966},[],{"@_xlink:href":1967},"fpubh-06-00149-i0007.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1972,":@":1979},[1973,1974,1978],{"#text":1061},{"bold":1975},[1976],{"#text":1977},"Step 7: Tests of Dimensionality: Testing if Latent Constructs Are as Hypothesized",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"#text":1053},{"tr":1983},[1984,1985,1990,1991,1996,1997,2016,2017,2035],{"#text":1057},{"td":1986,":@":1989},[1987],{"#text":1988},"Test dimensionality",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1992,":@":1995},[1993],{"#text":1994},"To address queries on the latent structure of scale items and their underlying relationships. i.e., to validate whether the previous hypothetical structure fits the items",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":1998,":@":2015},[1999,2001,2007,2009,2011,2013],{"#text":2000},"7.1 Estimate independent cluster model—confirmatory factor analysis, cf. Table ",{"xref":2002,":@":2004},[2003],{"#text":1245},{"@_ref-type":2005,"@_rid":2006},"table","T2",{"break":2008},[],{"#text":2010},"7.2 Estimate bifactor models to eliminate ambiguity about the type of dimensionality—unidimensionality, bidimensionality, or multi-dimensionality",{"break":2012},[],{"#text":2014},"7.3 Estimate measurement invariance to determine whether hypothesized factor and dimension is congruent across groups or multiple samples",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2018,":@":2034},[2019,2020,2026,2027,2033],{"#text":1189},{"xref":2021,":@":2024},[2022],{"#text":2023},"91",{"@_ref-type":898,"@_rid":2025},"B91",{"#text":917},{"xref":2028,":@":2031},[2029],{"#text":2030},"114",{"@_ref-type":898,"@_rid":2032},"B114",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2038},[2039,2040,2045,2046,2051,2052,2061,2062,2073],{"#text":1057},{"td":2041,":@":2044},[2042],{"#text":2043},"Score scale items",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2047,":@":2050},[2048],{"#text":2049},"To create scale scores for substantive analysis including reliability and validity of scale",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2053,":@":2060},[2054,2056,2058],{"#text":2055},"7.4. calculate scale scores using an unweighted approach, which includes summing standardized item scores and raw item scores, or computing the mean for raw item scores",{"break":2057},[],{"#text":2059},"7.5. Calculate scale scores by using a weighted approach, which includes creating factor scores via confirmatory factor analysis or structural equation models",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2063,":@":2072},[2064,2065,2071],{"#text":1189},{"xref":2066,":@":2069},[2067],{"#text":2068},"115",{"@_ref-type":898,"@_rid":2070},"B115",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2076,":@":2098},[2077,2078,2087,2088,2097],{"#text":1057},{"td":2079,":@":2086},[2080,2081,2085],{"#text":1061},{"inline-graphic":2082,":@":2083},[],{"@_xlink:href":2084},"fpubh-06-00149-i0008.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2089,":@":2096},[2090,2091,2095],{"#text":1061},{"bold":2092},[2093],{"#text":2094},"Step 8: Tests of Reliability: Establishing if Responses Are Consistent When Repeated",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"@_style":1295},{"#text":1053},{"tr":2101},[2102,2103,2108,2109,2114,2115,2124,2125,2143],{"#text":1057},{"td":2104,":@":2107},[2105],{"#text":2106},"Calculate reliability statistics",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2110,":@":2113},[2111],{"#text":2112},"To assess the internal consistency of the scale. i.e., the degree to which the set of items in the scale co-vary, relative to their sum score",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2116,":@":2123},[2117,2119,2121],{"#text":2118},"8.1 Estimate using Cronbach's alpha",{"break":2120},[],{"#text":2122},"8.2. Other tests such as Raykov's rho, ordinal alpha, and Revelle's beta can be used to assess scale reliability",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2126,":@":2142},[2127,2128,2134,2135,2141],{"#text":1189},{"xref":2129,":@":2132},[2130],{"#text":2131},"116",{"@_ref-type":898,"@_rid":2133},"B116",{"#text":917},{"xref":2136,":@":2139},[2137],{"#text":2138},"123",{"@_ref-type":898,"@_rid":2140},"B123",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2146},[2147,2148,2153,2154,2159,2160,2165,2166,2194],{"#text":1057},{"td":2149,":@":2152},[2150],{"#text":2151},"Test–retest reliability",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2155,":@":2158},[2156],{"#text":2157},"To assess the degree to which the participant's performance is repeatable; i.e., how consistent their scores are across time",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2161,":@":2164},[2162],{"#text":2163},"8.3 Estimate the strength of the relationship between scale items over two or three time points; variety of measures possible",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2167,":@":2193},[2168,2169,2173,2174,2178,2179,2185,2186,2192],{"#text":1189},{"xref":2170,":@":2172},[2171],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":2175,":@":2177},[2176],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2180,":@":2183},[2181],{"#text":2182},"124",{"@_ref-type":898,"@_rid":2184},"B124",{"#text":933},{"xref":2187,":@":2190},[2188],{"#text":2189},"125",{"@_ref-type":898,"@_rid":2191},"B125",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2197,":@":2219},[2198,2199,2208,2209,2218],{"#text":1057},{"td":2200,":@":2207},[2201,2202,2206],{"#text":1061},{"inline-graphic":2203,":@":2204},[],{"@_xlink:href":2205},"fpubh-06-00149-i0009.tif",{"#text":1057},{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2210,":@":2217},[2211,2212,2216],{"#text":1061},{"bold":2213},[2214],{"#text":2215},"Step 9: Tests of Validity: Ensuring You Measure the Latent Dimension You Intended",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":767},{"#text":1053},{"@_style":1295},{"#text":1053},{"tr":2222},[2223,2224,2233],{"#text":1057},{"td":2225,":@":2232},[2226,2227,2231],{"#text":1061},{"bold":2228},[2229],{"#text":2230},"Criterion validity",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":770},{"#text":1053},{"#text":1053},{"tr":2236},[2237,2238,2243,2244,2249,2250,2255,2256,2277],{"#text":1057},{"td":2239,":@":2242},[2240],{"#text":2241},"Predictive validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2245,":@":2248},[2246],{"#text":2247},"To determine if scores predict future outcomes",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2251,":@":2254},[2252],{"#text":2253},"9.1 Use bivariate and multivariable regression; stronger and significant associations or causal effects suggest greater predictive validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2257,":@":2276},[2258,2259,2263,2264,2268,2269,2275],{"#text":1189},{"xref":2260,":@":2262},[2261],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":2265,":@":2267},[2266],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2270,":@":2273},[2271],{"#text":2272},"31",{"@_ref-type":898,"@_rid":2274},"B31",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2280},[2281,2282,2287,2288,2293,2294,2299,2300,2309],{"#text":1057},{"td":2283,":@":2286},[2284],{"#text":2285},"Concurrent validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2289,":@":2292},[2290],{"#text":2291},"To determine the extent to which scale scores have a stronger relationship with criterion measurements made near the time of administration",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2295,":@":2298},[2296],{"#text":2297},"9.2 Estimate the association between scale scores and “gold standard” of scale measurement; stronger significant association in Pearson product-moment correlation suggests support for concurrent validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2301,":@":2308},[2302,2303,2307],{"#text":1189},{"xref":2304,":@":2306},[2305],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2312,":@":2324},[2313,2314,2323],{"#text":1057},{"td":2315,":@":2322},[2316,2317,2321],{"#text":1061},{"bold":2318},[2319],{"#text":2320},"Construct validity",{"#text":1057},{"@_valign":1068,"@_align":1069,"@_colspan":770},{"#text":1053},{"@_style":1295},{"#text":1053},{"tr":2327},[2328,2329,2334,2335,2340,2341,2346,2347,2370],{"#text":1057},{"td":2330,":@":2333},[2331],{"#text":2332},"Convergent validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2336,":@":2339},[2337],{"#text":2338},"To examine if the same concept measured in different ways yields similar results",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2342,":@":2345},[2343],{"#text":2344},"9.3 Estimate the relationship between scale scores and similar constructs using multi-trait multi-method matrix, latent variable modeling, or Pearson product-moment coefficient; higher/stronger correlation coefficients suggest support for convergent validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2348,":@":2369},[2349,2350,2354,2355,2361,2362,2368],{"#text":1189},{"xref":2351,":@":2353},[2352],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2356,":@":2359},[2357],{"#text":2358},"37",{"@_ref-type":898,"@_rid":2360},"B37",{"#text":933},{"xref":2363,":@":2366},[2364],{"#text":2365},"126",{"@_ref-type":898,"@_rid":2367},"B126",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2373},[2374,2375,2380,2381,2386,2387,2392,2393,2412],{"#text":1057},{"td":2376,":@":2379},[2377],{"#text":2378},"Discriminant validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2382,":@":2385},[2383],{"#text":2384},"To examine if the concept measured is different from some other concept",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2388,":@":2391},[2389],{"#text":2390},"9.4 Estimate the relationship between scale scores and distinct constructs using multi-trait multi-method matrix, latent variable modeling, or Pearson product-moment coefficient; lower/weaker correlation coefficients suggest support for discriminant validity",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2394,":@":2411},[2395,2396,2400,2401,2405,2406,2410],{"#text":1189},{"xref":2397,":@":2399},[2398],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2402,":@":2404},[2403],{"#text":2358},{"@_ref-type":898,"@_rid":2360},{"#text":933},{"xref":2407,":@":2409},[2408],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2415},[2416,2417,2422,2423,2428,2429,2440,2441,2455],{"#text":1057},{"td":2418,":@":2421},[2419],{"#text":2420},"Differentiation by “known groups”",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2424,":@":2427},[2425],{"#text":2426},"To examine if the concept measured behaves as expected in relation to “known groups”",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2430,":@":2439},[2431,2433,2437],{"#text":2432},"9.5 Select known binary variables based on theoretical and empirical knowledge and determine the distribution of the scale scores over the known groups; use ",{"italic":2434},[2435],{"#text":2436},"t",{"#text":2438},"-tests if binary, ANOVA if multiple groups",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2442,":@":2454},[2443,2444,2448,2449,2453],{"#text":1189},{"xref":2445,":@":2447},[2446],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2450,":@":2452},[2451],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":1053},{"tr":2458},[2459,2460,2465,2466,2471,2472,2477,2478,2501],{"#text":1057},{"td":2461,":@":2464},[2462],{"#text":2463},"Correlation analysis",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2467,":@":2470},[2468],{"#text":2469},"To determine the relationship between existing measures or variables and newly developed scale scores",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2473,":@":2476},[2474],{"#text":2475},"9.6 Correlate scale scores and existing measures or, preferably, use linear regression, intraclass correlation coefficient, and analysis of standard deviations of the differences between scores",{"@_valign":1068,"@_align":1069},{"#text":1057},{"td":2479,":@":2500},[2480,2481,2485,2486,2492,2493,2499],{"#text":1189},{"xref":2482,":@":2484},[2483],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2487,":@":2490},[2488],{"#text":2489},"127",{"@_ref-type":898,"@_rid":2491},"B127",{"#text":933},{"xref":2494,":@":2497},[2495],{"#text":2496},"128",{"@_ref-type":898,"@_rid":2498},"B128",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1053},{"#text":796},{"#text":802},{"@_frame":2505,"@_rules":2506},"hsides","groups",{"#text":877},{"@_position":1023,"@_id":2509},"T1",{"#text":880},{"@_id":2512},"s2",{"#text":880},{"sec":2515,":@":3105,"anchorId":3106},[2516,2517,2521,2522,2890,2891,3104],{"#text":877},{"title":2518},[2519],{"#text":2520},"Phase 1: item development",{"#text":877},{"sec":2523},[2524,2525,2529,2530,2581,2582,2889],{"#text":802},{"title":2526},[2527],{"#text":2528},"Step 1: identification of the domain(s) and item generation",{"#text":802},{"sec":2531},[2532,2533,2536,2537,2553,2554,2580],{"#text":796},{"title":2534},[2535],{"#text":1151},{"#text":796},{"p":2538},[2539,2541,2545,2547,2551],{"#text":2540},"The first step is to articulate the domain(s) that you are endeavoring to measure. A domain or construct refers to the concept, attribute, or unobserved behavior that is the target of the study (",{"xref":2542,":@":2544},[2543],{"#text":1206},{"@_ref-type":898,"@_rid":1208},{"#text":2546},"). Therefore, the domain being examined should be decided upon and defined before any item activity (",{"xref":2548,":@":2550},[2549],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":2552},"). A well-defined domain will provide a working knowledge of the phenomenon under study, specify the boundaries of the domain, and ease the process of item generation and content validation.",{"#text":796},{"p":2555},[2556,2558,2562,2564,2567,2569,2573,2575,2578],{"#text":2557},"McCoach et al. outline a number of steps in scale development; we find the first five to be suitable for the identification of domain (",{"xref":2559,":@":2561},[2560],{"#text":1198},{"@_ref-type":898,"@_rid":1200},{"#text":2563},"). These are all based on thorough literature review and include (a) specifying the purpose of the domain or construct you seek to develop, and (b), confirming that there are no existing instruments that will adequately serve the same purpose. Where there is a similar instrument in existence, you need to justify why the development of a new instrument is appropriate and how it will differ from existing instruments. Then, (c) describe the domain and provide a preliminary conceptual definition and (d) specify, if any, the dimensions of the domain. Alternatively, you can let the number of dimensions forming the domain to be determined through statistical computation (cf. Steps 5, 6, and 7). Domains are determined ",{"italic":2565},[2566],{"#text":1179},{"#text":2568}," if there is an established framework or theory guiding the study, but ",{"italic":2570},[2571],{"#text":2572},"a posteriori",{"#text":2574}," if none exist. Finally, if domains are identified ",{"italic":2576},[2577],{"#text":1179},{"#text":2579},", (e) the final conceptual definition for each domain should be specified.",{"#text":802},{"#text":802},{"sec":2583},[2584,2585,2588,2589,2612,2613,2658,2659,2671,2672,2717,2718,2751,2752,2762,2763,2775,2776,2787,2788,2805,2806,2823,2824,2857,2858,2877,2878,2888],{"#text":796},{"title":2586},[2587],{"#text":1220},{"#text":796},{"p":2590},[2591,2593,2599,2601,2605,2607,2611],{"#text":2592},"Once the domain is delineated, the item pool can then be identified. This process is also called “question development” (",{"xref":2594,":@":2597},[2595],{"#text":2596},"26",{"@_ref-type":898,"@_rid":2598},"B26",{"#text":2600},") or “item generation” (",{"xref":2602,":@":2604},[2603],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":2606},"). There are two ways to identify appropriate questions: deductive and inductive methods (",{"xref":2608,":@":2610},[2609],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":941},{"#text":796},{"p":2614},[2615,2617,2623,2625,2629,2630,2634,2636,2640,2641,2645,2647,2651,2653,2657],{"#text":2616},"The deductive method, also known as “logical partitioning” or “classification from above” (",{"xref":2618,":@":2621},[2619],{"#text":2620},"27",{"@_ref-type":898,"@_rid":2622},"B27",{"#text":2624},") is based on the description of the relevant domain and the identification of items. This can be done through literature review and assessment of existing scales and indicators of that domain (",{"xref":2626,":@":2628},[2627],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":2631,":@":2633},[2632],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":2635},"). The inductive method, also known as “grouping” or “classification from below” (",{"xref":2637,":@":2639},[2638],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":933},{"xref":2642,":@":2644},[2643],{"#text":2620},{"@_ref-type":898,"@_rid":2622},{"#text":2646},") involves the generation of items from the responses of individuals (",{"xref":2648,":@":2650},[2649],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":2652},"). Qualitative data obtained through direct observations and exploratory research methodologies, such as focus groups and individual interviews, can be used to inductively identify domain items (",{"xref":2654,":@":2656},[2655],{"#text":1252},{"@_ref-type":898,"@_rid":1254},{"#text":941},{"#text":796},{"p":2660},[2661,2663,2669],{"#text":2662},"It is considered best practice to combine both deductive and inductive methods to both define the domain and identify the questions to assess it. While the literature review provides the theoretical basis for defining the domain, the use of qualitative techniques moves the domain from an abstract point to the identification of its manifest forms. A scale or construct defined by theoretical underpinnings is better placed to make specific pragmatic decisions about the domain (",{"xref":2664,":@":2667},[2665],{"#text":2666},"28",{"@_ref-type":898,"@_rid":2668},"B28",{"#text":2670},"), as the construct will be based on accumulated knowledge of existing items.",{"#text":796},{"p":2673},[2674,2676,2680,2681,2685,2687,2691,2692,2698,2700,2704,2706,2710,2711,2715],{"#text":2675},"It is recommended that the items identified using deductive and inductive approaches should be broader and more comprehensive than one's own theoretical view of the target (",{"xref":2677,":@":2679},[2678],{"#text":2666},{"@_ref-type":898,"@_rid":2668},{"#text":933},{"xref":2682,":@":2684},[2683],{"#text":1568},{"@_ref-type":898,"@_rid":1570},{"#text":2686},"). Further, content should be included that ultimately will be shown to be tangential or unrelated to the core construct. In other words, one should not hesitate to have items on the scale that do not perfectly fit the domain identified, as successive evaluation will eliminate undesirable items from the initial pool. Kline and Schinka et al. note that the initial pool of items developed should be at minimum twice as long as the desired final scale (",{"xref":2688,":@":2690},[2689],{"#text":2596},{"@_ref-type":898,"@_rid":2598},{"#text":933},{"xref":2693,":@":2696},[2694],{"#text":2695},"30",{"@_ref-type":898,"@_rid":2697},"B30",{"#text":2699},"). Others have recommended the initial pool to be five times as large as the final version, to provide the requisite margin to select an optimum combination of items (",{"xref":2701,":@":2703},[2702],{"#text":2695},{"@_ref-type":898,"@_rid":2697},{"#text":2705},"). We agree with Kline and Schinka et al. (",{"xref":2707,":@":2709},[2708],{"#text":2596},{"@_ref-type":898,"@_rid":2598},{"#text":933},{"xref":2712,":@":2714},[2713],{"#text":2695},{"@_ref-type":898,"@_rid":2697},{"#text":2716},") that the number of items should be at least twice as long as the desired scale.",{"#text":796},{"p":2719},[2720,2722,2726,2728,2732,2734,2738,2740,2744,2746,2750],{"#text":2721},"Further, in the development of items, the ",{"italic":2723},[2724],{"#text":2725},"form",{"#text":2727}," of the items, the ",{"italic":2729},[2730],{"#text":2731},"wording of the items",{"#text":2733},", and the types of ",{"italic":2735},[2736],{"#text":2737},"responses",{"#text":2739}," that the question is designed to induce should be taken into account. It also means questions should capture the lived experiences of the phenomenon by target population (",{"xref":2741,":@":2743},[2742],{"#text":2695},{"@_ref-type":898,"@_rid":2697},{"#text":2745},"). Further, items should be worded simply and unambiguously. Items should not be offensive or potentially biased in terms of social identity, i.e., gender, religion, ethnicity, race, economic status, or sexual orientation (",{"xref":2747,":@":2749},[2748],{"#text":2695},{"@_ref-type":898,"@_rid":2697},{"#text":941},{"#text":796},{"p":2753},[2754,2756,2760],{"#text":2755},"Fowler identified five essential characteristics of items required to ensure the quality of construct measurement (",{"xref":2757,":@":2759},[2758],{"#text":2272},{"@_ref-type":898,"@_rid":2274},{"#text":2761},"). These include (a) the need for items to be consistently understood; (b) the need for items to be consistently administered or communicated to respondents; (c) the consistent communication of what constitutes an adequate answer; (d) the need for all respondents to have access to the information needed to answer the question accurately; and (e) the willingness for respondents to provide the correct answers required by the question at all times.",{"#text":796},{"p":2764},[2765,2767,2773],{"#text":2766},"These essentials are sometimes very difficult to achieve. Krosnick (",{"xref":2768,":@":2771},[2769],{"#text":2770},"32",{"@_ref-type":898,"@_rid":2772},"B32",{"#text":2774},") suggests that respondents can be less thoughtful about the meaning of a question, search their memories less comprehensively, integrate retrieved information less carefully, or even select a less precise response choice. All this means that they are merely satisficing, i.e., providing merely satisfactory answers, rather than the most accurate ones. In order to combat this behavior, questions should be kept simple, straightforward, and should follow the conventions of normal conversation.",{"#text":796},{"p":2777},[2778,2780,2786],{"#text":2779},"With regards to the type of responses to these questions, we recommend that questions with dichotomous response categories (e.g., true/false) should have no ambiguity. When a Likert-type response scale is used, the points on the scale should reflect the entire measurement continuum. Responses should be presented in an ordinal manner, i.e., in an ascending order without any overlap, and each point on the response scale should be meaningful and interpreted the same way by each participant to ensure data quality (",{"xref":2781,":@":2784},[2782],{"#text":2783},"33",{"@_ref-type":898,"@_rid":2785},"B33",{"#text":941},{"#text":796},{"p":2789},[2790,2792,2796,2798,2804],{"#text":2791},"In terms of the number of points on the response scale, Krosnick and Presser (",{"xref":2793,":@":2795},[2794],{"#text":2783},{"@_ref-type":898,"@_rid":2785},{"#text":2797},") showed that responses with just two to three points have lower reliability than Likert-type response scales with five to seven points. However, the gain levels off after seven points. Therefore, response scales with five points are recommended for unipolar items, i.e., those reflecting relative degrees of a single item response quality, e.g., not at all satisfied to very satisfied. Seven response items are recommended for bipolar items, i.e., those reflecting relative degrees of two qualities of an item response scale, e.g., completely dissatisfied to completely satisfied. As an analytic aside, items with scale points fewer than five categories are best estimated using robust categorical methods. However, items with five to seven categories without strong floor or ceiling effects can be treated as continuous items in confirmatory factor analysis and structural equation modeling using maximum likelihood estimations (",{"xref":2799,":@":2802},[2800],{"#text":2801},"34",{"@_ref-type":898,"@_rid":2803},"B34",{"#text":941},{"#text":796},{"p":2807},[2808,2810,2816,2818,2822],{"#text":2809},"One pitfall in the identification of domain and item generation is the improper conceptualization and definition of the domain(s). This can result in scales that may either be deficient because the definition of the domain is ambiguous or has been inadequately defined (",{"xref":2811,":@":2814},[2812],{"#text":2813},"35",{"@_ref-type":898,"@_rid":2815},"B35",{"#text":2817},"). It can also result in contamination, i.e., the definition of the domain overlaps with other existing constructs in the same field (",{"xref":2819,":@":2821},[2820],{"#text":2813},{"@_ref-type":898,"@_rid":2815},{"#text":941},{"#text":796},{"p":2825},[2826,2828,2832,2833,2839,2841,2845,2846,2850,2852,2856],{"#text":2827},"Caution should also be taken to avoid construct underrepresentation, which is when a scale does not capture important aspects of a construct because its focus is too narrow (",{"xref":2829,":@":2831},[2830],{"#text":2813},{"@_ref-type":898,"@_rid":2815},{"#text":933},{"xref":2834,":@":2837},[2835],{"#text":2836},"36",{"@_ref-type":898,"@_rid":2838},"B36",{"#text":2840},"). Further, construct-irrelevant variance, which is the degree to which test scores are influenced by processes that have little to do with the intended construct and seem to be widely inclusive of non-related items (",{"xref":2842,":@":2844},[2843],{"#text":2836},{"@_ref-type":898,"@_rid":2838},{"#text":933},{"xref":2847,":@":2849},[2848],{"#text":2358},{"@_ref-type":898,"@_rid":2360},{"#text":2851},"), should be avoided. Both construct underrepresentation and irrelevant variance can lead to the invalidation of the scale (",{"xref":2853,":@":2855},[2854],{"#text":2836},{"@_ref-type":898,"@_rid":2838},{"#text":941},{"#text":796},{"p":2859},[2860,2862,2868,2869,2875],{"#text":2861},"An example of best practice using the deductive approach to item generation is found in the work of Dennis on breastfeeding self-efficacy (",{"xref":2863,":@":2866},[2864],{"#text":2865},"38",{"@_ref-type":898,"@_rid":2867},"B38",{"#text":917},{"xref":2870,":@":2873},[2871],{"#text":2872},"40",{"@_ref-type":898,"@_rid":2874},"B40",{"#text":2876},"). Dennis' breastfeeding self-efficacy scale items were first informed by Bandura's theory on self-efficacy, followed by content analysis of literature review, and empirical studies on breastfeeding-related confidence.",{"#text":796},{"p":2879},[2880,2882,2886],{"#text":2881},"A valuable example for a rigorous inductive approach is found in the work of Frongillo and Nanama on the development and validation of an experience-based measure of household food insecurity in northern Burkina Faso (",{"xref":2883,":@":2885},[2884],{"#text":1264},{"@_ref-type":898,"@_rid":1266},{"#text":2887},"). In order to generate items for the measure, they undertook in-depth interviews with 10 household heads and 26 women using interview guides. The data from these interviews were thematically analyzed, with the results informing the identification of items to be added or deleted from the initial questionnaire. Also, the interviews led to the development and revision of answer choices.",{"#text":802},{"#text":877},{"#text":877},{"sec":2892},[2893,2894,2898,2899,2928,2929,2945,2946,2950,2951,3067,3068,3103],{"#text":802},{"title":2895},[2896],{"#text":2897},"Step 2: content validity",{"#text":802},{"p":2900},[2901,2903,2907,2909,2913,2915,2919,2921,2927],{"#text":2902},"Content validity, also known as “theoretical analysis” (",{"xref":2904,":@":2906},[2905],{"#text":1252},{"@_ref-type":898,"@_rid":1254},{"#text":2908},"), refers to the “adequacy with which a measure assesses the domain of interest” (",{"xref":2910,":@":2912},[2911],{"#text":986},{"@_ref-type":898,"@_rid":988},{"#text":2914},"). The need for content adequacy is vital if the items are to measure what they are presumed to measure (",{"xref":2916,":@":2918},[2917],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":2920},"). Additionally, content validity specifies content relevance and content representations, i.e., that the items capture the relevant experience of the target population being examined (",{"xref":2922,":@":2925},[2923],{"#text":2924},"129",{"@_ref-type":898,"@_rid":2926},"B129",{"#text":941},{"#text":802},{"p":2930},[2931,2933,2937,2939,2943],{"#text":2932},"Content validity entails the process of ensuring that only the phenomenon spelled out in the conceptual definition, but not other aspects that “might be related but are outside the investigator's intent for that particular [construct] are added” (",{"xref":2934,":@":2936},[2935],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":2938},"). Guion has proposed five conditions that must be satisfied in order for one to claim any form of content validity. We find these conditions to be broadly applicable to scale development in any discipline. These include that (a) the behavioral content has a generally accepted meaning or definition; (b) the domain is unambiguously defined; (c) the content domain is relevant to the purposes of measurement; (d) qualified judges agree that the domain has been adequately sampled based on consensus; and (e) the response content must be reliably observed and evaluated (",{"xref":2940,":@":2942},[2941],{"#text":1343},{"@_ref-type":898,"@_rid":1345},{"#text":2944},"). Therefore, content validity requires evidence of content relevance, representativeness, and technical quality.",{"#text":802},{"p":2947},[2948],{"#text":2949},"Content validity is mainly assessed through evaluation by expert and target population judges.",{"#text":802},{"sec":2952},[2953,2954,2957,2958,2979,2980,3038,3039,3050,3051,3066],{"#text":796},{"title":2955},[2956],{"#text":1303},{"#text":796},{"p":2959},[2960,2962,2966,2967,2971,2973,2977],{"#text":2961},"Expert judges are highly knowledgeable about the domain of interest and/or scale development; target population judges are potential users of the scale (",{"xref":2963,":@":2965},[2964],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":2968,":@":2970},[2969],{"#text":1252},{"@_ref-type":898,"@_rid":1254},{"#text":2972},"). Expert judges seem to be used more often than target-population judges in scale development work to date. Ideally, one should combine expert and target population judgment. When resources are constrained, however, we recommend ",{"italic":2974},[2975],{"#text":2976},"at least",{"#text":2978}," the use of expert judges.",{"#text":796},{"p":2981},[2982,2984,2988,2990,2996,2998,3004,3006,3010,3012,3018,3020,3026,3028,3032,3033,3037],{"#text":2983},"Expert judges evaluate each of the items to determine whether they represent the domain of interest. These expert judges should be independent of those who developed the item pool. Expert judgment can be done systematically to avoid bias in the assessment of items. Multiple judges have been used (typically ranging from 5 to 7) (",{"xref":2985,":@":2987},[2986],{"#text":1206},{"@_ref-type":898,"@_rid":1208},{"#text":2989},"). Their assessments have been quantified using formalized scaling and statistical procedures such as the content validity ratio for quantifying consensus (",{"xref":2991,":@":2994},[2992],{"#text":2993},"43",{"@_ref-type":898,"@_rid":2995},"B43",{"#text":2997},"), content validity index for measuring proportional agreement (",{"xref":2999,":@":3002},[3000],{"#text":3001},"44",{"@_ref-type":898,"@_rid":3003},"B44",{"#text":3005},"), or Cohen's coefficient kappa (",{"italic":3007},[3008],{"#text":3009},"k",{"#text":3011},") for measuring inter-rater or expert agreement (",{"xref":3013,":@":3016},[3014],{"#text":3015},"45",{"@_ref-type":898,"@_rid":3017},"B45",{"#text":3019},"). Among the three procedures, we recommend Cohen's coefficient kappa, which has been found to be most efficient (",{"xref":3021,":@":3024},[3022],{"#text":3023},"46",{"@_ref-type":898,"@_rid":3025},"B46",{"#text":3027},"). Additionally, an increase in the number of experts has been found to increase the robustness of the ratings (",{"xref":3029,":@":3031},[3030],{"#text":1206},{"@_ref-type":898,"@_rid":1208},{"#text":933},{"xref":3034,":@":3036},[3035],{"#text":3001},{"@_ref-type":898,"@_rid":3003},{"#text":941},{"#text":796},{"p":3040},[3041,3043,3049],{"#text":3042},"Another way by which content validity can be assessed through expert judges is by using the Delphi method to come to a consensus on which questions are a reflection of the construct you want to measure. The Delphi method is a technique “for structuring group communication process so that the process is effective in allowing a group of individuals, as a whole, to deal with a complex problem” (",{"xref":3044,":@":3047},[3045],{"#text":3046},"47",{"@_ref-type":898,"@_rid":3048},"B47",{"#text":941},{"#text":796},{"p":3052},[3053,3055,3059,3061,3065],{"#text":3054},"A good example of evaluation of content validity using expert judges is seen in the work of Augustine et al. on adolescent knowledge of micronutrients (",{"xref":3056,":@":3058},[3057],{"#text":1350},{"@_ref-type":898,"@_rid":1352},{"#text":3060},"). After identifying a list of items to be validated, the authors consulted experts in the field of nutrition, psychology, medicine, and basic sciences. The items were then subjected to content analysis using expert judges. Two independent reviews were carried out by a panel of five experts to select the questions that were appropriate, accurate, and interpretable. Items were either accepted, rejected, or modified based on majority opinion (",{"xref":3062,":@":3064},[3063],{"#text":1350},{"@_ref-type":898,"@_rid":1352},{"#text":941},{"#text":802},{"#text":802},{"sec":3069},[3070,3071,3074,3075,3091,3092,3102],{"#text":796},{"title":3072},[3073],{"#text":1363},{"#text":796},{"p":3076},[3077,3079,3083,3085,3089],{"#text":3078},"Target population judges are experts at evaluating face validity, which is a component of content validity (",{"xref":3080,":@":3082},[3081],{"#text":1206},{"@_ref-type":898,"@_rid":1208},{"#text":3084},"). Face validity is the “degree that respondents or end users [or lay persons] judge that the items of an assessment instrument are appropriate to the targeted construct and assessment objectives” (",{"xref":3086,":@":3088},[3087],{"#text":1206},{"@_ref-type":898,"@_rid":1208},{"#text":3090},"). These end-users are able to tell whether the construct is a good measure of the domain through cognitive interviews, which we discuss in Step 3.",{"#text":796},{"p":3093},[3094,3096,3100],{"#text":3095},"An example of the concurrent use of expert and target population judges comes from Boateng et al.'s work to develop a household-level water insecurity scale appropriate for use in western Kenya (",{"xref":3097,":@":3099},[3098],{"#text":1384},{"@_ref-type":898,"@_rid":1386},{"#text":3101},"). We used the Delphi method to obtain three rounds of feedback from international experts including those in hydrology, geography, WASH and water-related programs, policy implementation, and food insecurity. Each of the three rounds was interspersed with focus group discussions with our target population, i.e., people living in western Kenya. In each round, the questionnaires progressively became more closed ended, until consensus was attained on the definition of the domain we were studying and possible items we could use.",{"#text":802},{"#text":877},{"#text":880},{"@_id":3106},"s3",{"#text":880},{"sec":3109,":@":4099,"anchorId":4100},[3110,3111,3115,3116,3257,3258,3510,3511,3988,3989,4098],{"#text":877},{"title":3112},[3113],{"#text":3114},"Phase 2: scale development",{"#text":877},{"sec":3117},[3118,3119,3123,3124,3128,3129,3138,3139,3256],{"#text":802},{"title":3120},[3121],{"#text":3122},"Step 3: pre-testing questions",{"#text":802},{"p":3125},[3126],{"#text":3127},"Pre-testing helps to ensure that items are meaningful to the target population before the survey is actually administered, i.e., it minimizes misunderstanding and subsequent measurement error. Because pre-testing eliminates poorly worded items and facilitates revision of phrasing to be maximally understood, it also serves to reduce the cognitive burden on research participants. Finally, pre-testing represents an additional way in which members of the target population can participate in the research process by contributing their insights to the development of the survey.",{"#text":802},{"p":3130},[3131,3133,3137],{"#text":3132},"Pre-testing has two components: the first is the examination of the extent to which the questions reflect the domain being studied. The second is the examination of the extent to which answers to the questions asked produce valid measurements (",{"xref":3134,":@":3136},[3135],{"#text":2272},{"@_ref-type":898,"@_rid":2274},{"#text":941},{"#text":802},{"sec":3140},[3141,3142,3145,3146,3150,3151,3188,3189,3214,3215,3244,3245,3255],{"#text":796},{"title":3143},[3144],{"#text":1440},{"#text":796},{"p":3147},[3148],{"#text":3149},"To evaluate whether the questions reflect the domain of study and meet the requisite standards, techniques including cognitive interviews, focus group discussion, and field pre-testing under realistic conditions can be used. We describe the most recommended, which is cognitive interviews.",{"#text":796},{"p":3152},[3153,3155,3159,3161,3165,3166,3172,3174,3180,3181,3187],{"#text":3154},"Cognitive interviewing entails the administration of draft survey questions to target populations and then asking the respondents to verbalize the mental process entailed in providing such answers (",{"xref":3156,":@":3158},[3157],{"#text":1461},{"@_ref-type":898,"@_rid":1463},{"#text":3160},"). Generally, cognitive interviews allow for questions to be modified, clarified, or augmented to fit the objectives of the study. This approach helps to determine whether the question is generating the information that the author intends by helping to ensure that respondents understand questions as developers intended and that respondents are able to answer in a manner that reflects their experience (",{"xref":3162,":@":3164},[3163],{"#text":1461},{"@_ref-type":898,"@_rid":1463},{"#text":933},{"xref":3167,":@":3170},[3168],{"#text":3169},"50",{"@_ref-type":898,"@_rid":3171},"B50",{"#text":3173},"). This can be done on a sample outside of the study population or on a subset of study participants, but it must be explored before the questionnaire is finalized (",{"xref":3175,":@":3178},[3176],{"#text":3177},"51",{"@_ref-type":898,"@_rid":3179},"B51",{"#text":933},{"xref":3182,":@":3185},[3183],{"#text":3184},"52",{"@_ref-type":898,"@_rid":3186},"B52",{"#text":941},{"#text":796},{"p":3190},[3191,3193,3197,3199,3203,3204,3208,3209,3213],{"#text":3192},"The sample used for cognitive interviewing should capture the range of demographics you anticipate surveying (",{"xref":3194,":@":3196},[3195],{"#text":1461},{"@_ref-type":898,"@_rid":1463},{"#text":3198},"). A range of 5–15 interviews in two to three rounds, or until saturation, or relatively few new insights emerge is considered ideal for pre-testing (",{"xref":3200,":@":3202},[3201],{"#text":1461},{"@_ref-type":898,"@_rid":1463},{"#text":933},{"xref":3205,":@":3207},[3206],{"#text":3177},{"@_ref-type":898,"@_rid":3179},{"#text":933},{"xref":3210,":@":3212},[3211],{"#text":3184},{"@_ref-type":898,"@_rid":3186},{"#text":941},{"#text":796},{"p":3216},[3217,3219,3223,3225,3229,3231,3235,3236,3242],{"#text":3218},"In sum, cognitive interviews get to the heart of both assessing the appropriateness of the question to the target population ",{"italic":3220},[3221],{"#text":3222},"and",{"#text":3224}," the strength of the responses (",{"xref":3226,":@":3228},[3227],{"#text":1461},{"@_ref-type":898,"@_rid":1463},{"#text":3230},"). The advantages of using cognitive interviewing include: (a) it ensures questions are producing the intended data, (b) questions that are confusing to participants are identified and improved for clarity, (c) problematic questions or questions that are difficult to answer are identified, (d) it ensures response options are appropriate and adequate, (e) it reveals the thought process of participants on domain items, and (f) it can indicate problematic question order (",{"xref":3232,":@":3234},[3233],{"#text":3184},{"@_ref-type":898,"@_rid":3186},{"#text":933},{"xref":3237,":@":3240},[3238],{"#text":3239},"53",{"@_ref-type":898,"@_rid":3241},"B53",{"#text":3243},"). Outcomes of cognitive interviews should always be reported, along with solutions used to remedy the situation.",{"#text":796},{"p":3246},[3247,3249,3253],{"#text":3248},"An example of best practice in pre-testing is seen in the work of Morris et al. (",{"xref":3250,":@":3252},[3251],{"#text":1468},{"@_ref-type":898,"@_rid":1470},{"#text":3254},"). They developed and validated a novel scale for measuring interpersonal factors underlying injection drug use behaviors among injecting partners. After item development and expert judgment, they conducted cognitive interviews with seven respondents with similar characteristics to the target population to refine and assess item interpretation and to finalize item structure. Eight items were dropped after cognitive interviews for lack of clarity or importance. They also made modifications to grammar, word choice, and answer options based on the feedback from cognitive interviews.",{"#text":802},{"#text":877},{"#text":877},{"sec":3259},[3260,3261,3265,3266,3365,3366,3478,3479,3509],{"#text":802},{"title":3262},[3263],{"#text":3264},"Step 4: survey administration and sample size",{"#text":802},{"sec":3267},[3268,3269,3272,3273,3313,3314,3346,3347,3364],{"#text":796},{"title":3270},[3271],{"#text":1506},{"#text":796},{"p":3274},[3275,3277,3283,3285,3290,3292,3296,3298,3303,3305,3311],{"#text":3276},"Collecting data with minimum measurement errors from an adequate sample size is imperative. These data can be collected using paper and pen/pencil interviewing (PAPI) or Computer Assisted Personal Interviewing (CAPI) on devices like laptops, tablets, or phones. A number of software programs exist for building forms on devices. These include Computer Assisted Survey Information Collection (CASIC) Builder™ (West Portal Software Corporation, San Francisco, CA); Qualtrics Research Core™ (",{"ext-link":3278,":@":3281},[3279],{"#text":3280},"www.qualtrics.com",{"@_ext-link-type":844,"@_xlink:href":3282},"http://www.qualtrics.com",{"#text":3284},"); Open Data Kit (ODK, ",{"ext-link":3286,":@":3289},[3287],{"#text":3288},"https://opendatakit.org/",{"@_ext-link-type":844,"@_xlink:href":3288},{"#text":3291},"); Research Electronic Data Capture (REDCap) (",{"xref":3293,":@":3295},[3294],{"#text":1527},{"@_ref-type":898,"@_rid":1529},{"#text":3297},"); SurveyCTO (Dobility, Inc. ",{"ext-link":3299,":@":3302},[3300],{"#text":3301},"https://www.surveycto.com",{"@_ext-link-type":844,"@_xlink:href":3301},{"#text":3304},"); and Questionnaire Development System™ (QDS, ",{"ext-link":3306,":@":3309},[3307],{"#text":3308},"www.novaresearch.com",{"@_ext-link-type":844,"@_xlink:href":3310},"http://www.novaresearch.com",{"#text":3312},"), which allows the participant to report sensitive audio data.",{"#text":796},{"p":3315},[3316,3318,3324,3325,3329,3330,3336,3338,3344],{"#text":3317},"Each approach has advantages and drawbacks. Using technology can reduce the errors associated with data entry, allow the collection of data from large samples with minimal cost, increase response rate, reduce enumerator errors, permit instant feedback, and increase monitoring of data collection and ability to get more confidential data (",{"xref":3319,":@":3322},[3320],{"#text":3321},"56",{"@_ref-type":898,"@_rid":3323},"B56",{"#text":917},{"xref":3326,":@":3328},[3327],{"#text":1534},{"@_ref-type":898,"@_rid":1536},{"#text":933},{"xref":3331,":@":3334},[3332],{"#text":3333},"130",{"@_ref-type":898,"@_rid":3335},"B130",{"#text":3337},"). A subset of technology-based programs offers the option of attaching audio files to the survey questions so that questions may be recorded and read out loud to participants with low literacy via audio computer self-assisted interviewing (A-CASI) (",{"xref":3339,":@":3342},[3340],{"#text":3341},"131",{"@_ref-type":898,"@_rid":3343},"B131",{"#text":3345},"). Self-interviewing, whether via A-CASI or via computer-assisted personal interviewing, in which participants read and respond to questions on a computer without interviewer involvement, may increase reports of sensitive or stigmatized behaviors such as sexual behaviors and substance use, compared to when being asked by another human.",{"#text":796},{"p":3348},[3349,3351,3357,3358,3362],{"#text":3350},"On the other hand, paper forms may avert the crisis of losing data if the software crashes, the devices are lost or stolen prior to being backed up, and may be more suitable in areas that have irregular electricity and/or internet. However, as sample sizes increase, the use of PAPI becomes more expensive, time and labor intensive, and the data are exposed in several ways to human error (",{"xref":3352,":@":3355},[3353],{"#text":3354},"57",{"@_ref-type":898,"@_rid":3356},"B57",{"#text":933},{"xref":3359,":@":3361},[3360],{"#text":1534},{"@_ref-type":898,"@_rid":1536},{"#text":3363},"). Based on the merits of CAPI over PAPI, we recommend researchers use CAPI in data collection for surveys when feasible.",{"#text":802},{"#text":802},{"sec":3367},[3368,3369,3372,3373,3388,3389,3450,3451,3477],{"#text":796},{"title":3370},[3371],{"#text":1547},{"#text":796},{"p":3374},[3375,3377,3381,3383,3387],{"#text":3376},"The sample size to use for the development of a latent construct has often been contentious. It is recommended that potential scale items be tested on a heterogeneous sample, i.e., a sample that both reflects and captures the range of the target population (",{"xref":3378,":@":3380},[3379],{"#text":1568},{"@_ref-type":898,"@_rid":1570},{"#text":3382},"). For example, when the scale is used in a clinical setting, Clark and Watson recommend using patient samples early on instead of a sample from the general population (",{"xref":3384,":@":3386},[3385],{"#text":1568},{"@_ref-type":898,"@_rid":1570},{"#text":941},{"#text":796},{"p":3390},[3391,3393,3397,3399,3405,3407,3411,3413,3419,3420,3426,3428,3432,3434,3440,3442,3448],{"#text":3392},"The necessary sample size is dependent on several aspects of any given study, including the level of variation between the variables, and the level of over-determination (i.e., the ratio of variables to number of factors) of the factors (",{"xref":3394,":@":3396},[3395],{"#text":1575},{"@_ref-type":898,"@_rid":1577},{"#text":3398},"). The rule of thumb has been at least 10 participants for each scale item, i.e., an ideal ratio of respondents to items is 10:1 (",{"xref":3400,":@":3403},[3401],{"#text":3402},"60",{"@_ref-type":898,"@_rid":3404},"B60",{"#text":3406},"). However, others have suggested sample sizes that are independent of the number of survey items. Clark and Watson (",{"xref":3408,":@":3410},[3409],{"#text":1568},{"@_ref-type":898,"@_rid":1570},{"#text":3412},") propose using 300 respondents after initial pre-testing. Others have recommended a range of 200–300 as appropriate for factor analysis (",{"xref":3414,":@":3417},[3415],{"#text":3416},"61",{"@_ref-type":898,"@_rid":3418},"B61",{"#text":933},{"xref":3421,":@":3424},[3422],{"#text":3423},"62",{"@_ref-type":898,"@_rid":3425},"B62",{"#text":3427},"). Based on their simulation study using different sample sizes, Guadagnoli and Velicer (",{"xref":3429,":@":3431},[3430],{"#text":3416},{"@_ref-type":898,"@_rid":3418},{"#text":3433},") suggested that a minimum of 300–450 is required to observe an acceptable comparability of patterns, and that replication is required if the sample size is \u003C 300. Comrey and Lee suggest a graded scale of sample sizes for scale development: 100 = poor, 200 = fair, 300 = good, 500 = very good, ≥1,000 = excellent (",{"xref":3435,":@":3438},[3436],{"#text":3437},"63",{"@_ref-type":898,"@_rid":3439},"B63",{"#text":3441},"). Additionally, item reduction procedures (described, below in Step 5), such as parallel analysis which requires bootstrapping (estimating statistical parameters from sample by means of resampling with replacement) (",{"xref":3443,":@":3446},[3444],{"#text":3445},"64",{"@_ref-type":898,"@_rid":3447},"B64",{"#text":3449},"), may require larger data sets.",{"#text":796},{"p":3452},[3453,3455,3459,3460,3464,3466,3470,3471,3475],{"#text":3454},"In sum, there is no single item-ratio that works for all survey development scenarios. A larger sample size or respondent: item ratio is always better, since a larger sample size implies lower measurement errors and more, stable factor loadings, replicable factors, and generalizable results to the true population structure (",{"xref":3456,":@":3458},[3457],{"#text":1575},{"@_ref-type":898,"@_rid":1577},{"#text":933},{"xref":3461,":@":3463},[3462],{"#text":1582},{"@_ref-type":898,"@_rid":1584},{"#text":3465},"). A smaller sample size or respondent: item ratio may mean more unstable loadings and factors, random, non-replicable factors, and non-generalizable results (",{"xref":3467,":@":3469},[3468],{"#text":1575},{"@_ref-type":898,"@_rid":1577},{"#text":933},{"xref":3472,":@":3474},[3473],{"#text":1582},{"@_ref-type":898,"@_rid":1584},{"#text":3476},"). Sample size is, however, always constrained by resources available, and more often than not, scale development can be difficult to fund.",{"#text":802},{"#text":802},{"sec":3480},[3481,3482,3485,3486,3490,3491,3508],{"#text":796},{"title":3483},[3484],{"#text":1595},{"#text":796},{"p":3487},[3488],{"#text":3489},"The development of a scale minimally requires data from a single point in time. To fully test for the reliability of the scale (cf. Steps 8, 9), however, either an independent dataset or a subsequent time point is necessary. Data from longitudinal studies can be used for initial scale development (e.g., from baseline), to conduct confirmatory factor analysis (using follow-up data, cf. Step 7), and to assess test–retest reliability (using baseline and follow-up data). The problem with using longitudinal data to test hypothesized latent structures is common error variance, since the same, potentially idiosyncratic, participants will be involved. To give the most credence to the reliability of scale, the ideal procedure is to develop the scale on sample A, whether cross-sectional or longitudinal, and then test it on an independent sample B.",{"#text":796},{"p":3492},[3493,3495,3501,3503,3507],{"#text":3494},"The work of Chesney et al. on the Coping Self-Efficacy scale provides an example of this best practice in the use of independent samples (",{"xref":3496,":@":3499},[3497],{"#text":3498},"132",{"@_ref-type":898,"@_rid":3500},"B132",{"#text":3502},"). This study sought to investigate the psychometric characteristics of the Coping Self-Efficacy (CSE) scale, and their samples came from two independent randomized clinical trials. As such, two independent samples with four different time points each (0, 3, 6, and 12 months) were used. The authors administered the 26-item scale to the sample from the first clinical trial and examined the covariance that existed between all the scale items (exploratory factor analysis) giving the hypothesized factor structure across time in that one trial. The obtained factor structure was then fitted to baseline data from the second randomized clinical trial to test the hypothesized factor structure generated in the first sample (",{"xref":3504,":@":3506},[3505],{"#text":3498},{"@_ref-type":898,"@_rid":3500},{"#text":941},{"#text":802},{"#text":877},{"#text":877},{"sec":3512},[3513,3514,3518,3519,3531,3532,3559,3560,3593,3594,3608,3609,3690,3691,3824,3825,3884,3885,3935,3936,3987],{"#text":802},{"title":3515},[3516],{"#text":3517},"Step 5: item reduction analysis",{"#text":802},{"p":3520},[3521,3523,3529],{"#text":3522},"In scale development, item reduction analysis is conducted to ensure that only parsimonious, functional, and internally consistent items are ultimately included (",{"xref":3524,":@":3527},[3525],{"#text":3526},"133",{"@_ref-type":898,"@_rid":3528},"B133",{"#text":3530},"). Therefore, the goal of this phase is to identify items that are not or are the least-related to the domain under study for deletion or modification.",{"#text":802},{"p":3533},[3534,3536,3542,3544,3550,3551,3557],{"#text":3535},"Two theories, Classical Test Theory (CTT) and the Item Response Theory (IRT), underpin scale development (",{"xref":3537,":@":3540},[3538],{"#text":3539},"134",{"@_ref-type":898,"@_rid":3541},"B134",{"#text":3543},"). CTT is considered the traditional test theory and IRT the modern test theory; both function to produce latent constructs. Each theory may be used singly or in conjunction to complement the other's strengths (",{"xref":3545,":@":3548},[3546],{"#text":3547},"15",{"@_ref-type":898,"@_rid":3549},"B15",{"#text":933},{"xref":3552,":@":3555},[3553],{"#text":3554},"135",{"@_ref-type":898,"@_rid":3556},"B135",{"#text":3558},"). Whether the researcher is using CTT or IRT, the primary goal is to obtain functional items (i.e., items that are correlated with each other, discriminate between individual cases, underscore a single or multidimensional domain, and contribute significantly to the construct).",{"#text":802},{"p":3561},[3562,3564,3570,3572,3578,3580,3586,3588,3592],{"#text":3563},"CTT allows the prediction of outcomes of constructs and the difficulty of items (",{"xref":3565,":@":3568},[3566],{"#text":3567},"136",{"@_ref-type":898,"@_rid":3569},"B136",{"#text":3571},"). CTT models assume that items forming constructs in their observed, manifest forms consist of a true score on the domain of interest and a random error (which is the differences between the true score and a set of observed scores by an individual) (",{"xref":3573,":@":3576},[3574],{"#text":3575},"137",{"@_ref-type":898,"@_rid":3577},"B137",{"#text":3579},"). IRT seeks to model the way in which constructs manifest themselves in terms of observable item response (",{"xref":3581,":@":3584},[3582],{"#text":3583},"138",{"@_ref-type":898,"@_rid":3585},"B138",{"#text":3587},"). Comparatively, the IRT approach to scale development has the advantage of allowing the researcher to determine the effect of adding or deleting a given item or set of items by examining the item information and standard error functions for the item pool (",{"xref":3589,":@":3591},[3590],{"#text":3583},{"@_ref-type":898,"@_rid":3585},{"#text":941},{"#text":802},{"p":3595},[3596,3598,3602,3603,3607],{"#text":3597},"Several techniques exist within the two theories to reduce the item pool, depending on which test theory is driving the scale. The five major techniques used are: item difficulty and item discrimination indices, which are primarily for binary responses; inter-item and item-total correlations, which are mostly used for categorical items; and distractor efficiency analysis for items with multiple choice response options (",{"xref":3599,":@":3601},[3600],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":3604,":@":3606},[3605],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":941},{"#text":802},{"sec":3610},[3611,3612,3615,3616,3626,3627,3642,3643,3661,3662,3689],{"#text":796},{"title":3613},[3614],{"#text":1651},{"#text":796},{"p":3617},[3618,3620,3624],{"#text":3619},"The item difficulty index is both a CTT and an IRT parameter that can be traced largely to educational and psychological testing to assess the relative difficulties and discrimination abilities of test items (",{"xref":3621,":@":3623},[3622],{"#text":1682},{"@_ref-type":898,"@_rid":1684},{"#text":3625},"). Subsequently, this approach has been applied to more attitudinal-type scales designed to measure latent constructs.",{"#text":796},{"p":3628},[3629,3631,3635,3636,3640],{"#text":3630},"Under the CTT framework, the item difficulty index, also called item easiness, is the proportion of correct answers on a given item, e.g., the proportion of correct answers on a math test (",{"xref":3632,":@":3634},[3633],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":3637,":@":3639},[3638],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":3641},"). It ranges between 0.0 and 1.0. A high difficulty score means a greater proportion of the sample answered the question correctly. A lower difficulty score means a smaller proportion of the sample understood the question and answered correctly. This may be due to the item being coded wrongly, ambiguity with the item, confusing language, or ambiguity with response options. A lower difficulty score suggests a need to modify the items or delete them from the pool of items.",{"#text":796},{"p":3644},[3645,3647,3653,3655,3659],{"#text":3646},"Under the IRT framework, the item difficulty parameter is the probability of a particular examinee correctly answering any given item (",{"xref":3648,":@":3651},[3649],{"#text":3650},"67",{"@_ref-type":898,"@_rid":3652},"B67",{"#text":3654},"). This has the advantage of allowing the researcher to identify the different levels of individual performance on specific questions, as well as develop particular questions to specific subgroups or populations (",{"xref":3656,":@":3658},[3657],{"#text":3650},{"@_ref-type":898,"@_rid":3652},{"#text":3660},"). Item difficulty is estimated directly using logistic models instead of proportions.",{"#text":796},{"p":3663},[3664,3666,3670,3672,3676,3677,3681,3683,3687],{"#text":3665},"Researchers must determine whether they need items with low, medium, or high difficulty. For instance, researchers interested in general purpose scales will focus on items with medium difficulty (",{"xref":3667,":@":3669},[3668],{"#text":1689},{"@_ref-type":898,"@_rid":1691},{"#text":3671},"), i.e., the proportion with item assertions ranging from 0.4 to 0.6 (",{"xref":3673,":@":3675},[3674],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":3678,":@":3680},[3679],{"#text":1689},{"@_ref-type":898,"@_rid":1691},{"#text":3682},"). The item difficulty index can be calculated using existing commands in M",{"italic":3684},[3685],{"#text":3686},"plus",{"#text":3688},", R, SAS, SPSS, or Stata.",{"#text":802},{"#text":802},{"sec":3692},[3693,3694,3698,3699,3728,3729,3764,3765,3782,3783,3823],{"#text":796},{"title":3695},[3696],{"#text":3697},"Item discrimination index",{"#text":796},{"p":3700},[3701,3703,3707,3709,3713,3715,3721,3723,3727],{"#text":3702},"The item discrimination index (also called item-effectiveness test), is the degree to which an item correctly differentiates between respondents or examinees on a construct of interest (",{"xref":3704,":@":3706},[3705],{"#text":1723},{"@_ref-type":898,"@_rid":1725},{"#text":3708},"), and can be assessed under both CTT and IRT frameworks. It is a measure of the difference in performance between groups on a construct. The upper group represents participants with high scores and the lower group those with poor or low scores. The item discrimination index is “calculated by subtracting the proportion of examinees in the lower group (lower %) from the proportion of examinees in the upper group (upper %) who got the item correct or endorsed the item in the expected manner” (",{"xref":3710,":@":3712},[3711],{"#text":1723},{"@_ref-type":898,"@_rid":1725},{"#text":3714},"). It differentiates between the number of students in an upper group who get an item correct and the number of students in a lower group who get the item correct (",{"xref":3716,":@":3719},[3717],{"#text":3718},"70",{"@_ref-type":898,"@_rid":3720},"B70",{"#text":3722},"). The use of an item discrimination index enables the identification of positively discriminating items (i.e., items that differentiate rightly between those who are knowledgeable about a subject and those who are not), negatively discriminating items (i.e., items which are poorly designed such that the more knowledgeable get them wrong and the less knowledgeable get them right), and non-discriminating item (i.e., items that fail to differentiate between participants who are knowledgeable about a subject and those who are not) (",{"xref":3724,":@":3726},[3725],{"#text":3718},{"@_ref-type":898,"@_rid":3720},{"#text":941},{"#text":796},{"p":3730},[3731,3733,3739,3741,3745,3746,3750,3752,3756,3758,3762],{"#text":3732},"The item discrimination index has been found to improve test items in at least three ways. First, non-discriminating items, which fail to discriminate between respondents because they may be too easy, too hard, or ambiguous, should be removed (",{"xref":3734,":@":3737},[3735],{"#text":3736},"71",{"@_ref-type":898,"@_rid":3738},"B71",{"#text":3740},"). Second, items which negatively discriminate, e.g., items which fail to differentiate rightly between medically diagnosed depressed and non-depressed respondents on a happiness scale, should be reexamined and modified (",{"xref":3742,":@":3744},[3743],{"#text":3718},{"@_ref-type":898,"@_rid":3720},{"#text":933},{"xref":3747,":@":3749},[3748],{"#text":3736},{"@_ref-type":898,"@_rid":3738},{"#text":3751},"). Third, items that positively discriminate should be retained, e.g., items that are correctly affirmed by a greater proportion of respondents who are medically free of depression, with very low affirmation by respondents diagnosed to be medically depressed (",{"xref":3753,":@":3755},[3754],{"#text":3736},{"@_ref-type":898,"@_rid":3738},{"#text":3757},"). In some cases, it has been recommended that such positively discriminating items be considered for revision (",{"xref":3759,":@":3761},[3760],{"#text":3718},{"@_ref-type":898,"@_rid":3720},{"#text":3763},") as the differences could be due to the level of difficulty of the item.",{"#text":796},{"p":3766},[3767,3769,3773,3775,3781],{"#text":3768},"An item discrimination index can be calculated through correlational analysis between the performance on an item and an overall criterion (",{"xref":3770,":@":3772},[3771],{"#text":1723},{"@_ref-type":898,"@_rid":1725},{"#text":3774},") using either the point biserial correlation coefficient or the phi coefficient (",{"xref":3776,":@":3779},[3777],{"#text":3778},"72",{"@_ref-type":898,"@_rid":3780},"B72",{"#text":941},{"#text":796},{"p":3784},[3785,3787,3793,3795,3799,3800,3806,3807,3811,3813,3816,3818,3822],{"#text":3786},"Item discrimination under the IRT framework is a slope parameter that determines how steeply the probability of a correct response changes as the proficiency or trait increases (",{"xref":3788,":@":3791},[3789],{"#text":3790},"73",{"@_ref-type":898,"@_rid":3792},"B73",{"#text":3794},"). This allows differentiation between individuals with similar abilities and can also be estimated using a logistic model. Under certain conditions, the biserial correlation coefficient under the CTT framework has proven to be identical to the IRT item discrimination parameter (",{"xref":3796,":@":3798},[3797],{"#text":3650},{"@_ref-type":898,"@_rid":3652},{"#text":933},{"xref":3801,":@":3804},[3802],{"#text":3803},"74",{"@_ref-type":898,"@_rid":3805},"B74",{"#text":933},{"xref":3808,":@":3810},[3809],{"#text":1730},{"@_ref-type":898,"@_rid":1732},{"#text":3812},"); thus, as the trait increases so does the probability of endorsing an item. These parameters can be computed using existing commands in M",{"italic":3814},[3815],{"#text":3686},{"#text":3817},", R, SAS, SPSS, or Stata. In both CTT and IRT, higher values are indicators of greater discrimination (",{"xref":3819,":@":3821},[3820],{"#text":3790},{"@_ref-type":898,"@_rid":3792},{"#text":941},{"#text":802},{"#text":802},{"sec":3826},[3827,3828,3831,3832,3836,3837,3863,3864,3883],{"#text":796},{"title":3829},[3830],{"#text":1743},{"#text":796},{"p":3833},[3834],{"#text":3835},"A third technique to support the deletion or modification of items is the estimation of inter-item and item-total correlations, which falls under CTT. These correlations often displayed in the form of a matrix are used to examine relationships that exist between individual items in a pool.",{"#text":796},{"p":3838},[3839,3841,3845,3846,3850,3851,3855,3857,3861],{"#text":3840},"Inter-item correlations (also known as polychoric correlations for categorical variables and tetrachoric correlations for binary items) examines the extent to which scores on one item are related to scores on all other items in a scale (",{"xref":3842,":@":3844},[3843],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":3847,":@":3849},[3848],{"#text":1689},{"@_ref-type":898,"@_rid":1691},{"#text":933},{"xref":3852,":@":3854},[3853],{"#text":1779},{"@_ref-type":898,"@_rid":1781},{"#text":3856},"). Also, it examines the extent to which items on a scale are assessing the same content (",{"xref":3858,":@":3860},[3859],{"#text":1779},{"@_ref-type":898,"@_rid":1781},{"#text":3862},"). Items with very low correlations (\u003C 0.30) are less desirable and could be a cue for potential deletion from the tentative scale.",{"#text":796},{"p":3865},[3866,3868,3872,3873,3877,3879,3882],{"#text":3867},"Item-total correlations (also known as polyserial correlations for categorical variables and biserial correlations for binary items) aim at examining the relationship between each item vs. the total score of scale items. However, the adjusted item-total correlation, which examines the correlation between the item and the sum score of the rest of the items excluding itself is preferred (",{"xref":3869,":@":3871},[3870],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":3874,":@":3876},[3875],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":3878},"). Items with very low adjusted item-total correlations (\u003C 0.30) are less desirable and could be a cue for potential deletion from the tentative scale. Inter-item and item total correlations can be calculated using M",{"italic":3880},[3881],{"#text":3686},{"#text":3688},{"#text":802},{"#text":802},{"sec":3886},[3887,3888,3891,3892,3934],{"#text":796},{"title":3889},[3890],{"#text":1792},{"#text":796},{"p":3893},[3894,3896,3900,3902,3908,3910,3914,3916,3920,3921,3927,3929,3933],{"#text":3895},"The distractor efficiency analysis shows the distribution of incorrect options and how they contribute to the quality of a multiple-choice item (",{"xref":3897,":@":3899},[3898],{"#text":1813},{"@_ref-type":898,"@_rid":1815},{"#text":3901},"). The incorrect options, also known as distractors, are intentionally added in the response options to attract students who do not know the correct answer in a test question (",{"xref":3903,":@":3906},[3904],{"#text":3905},"78",{"@_ref-type":898,"@_rid":3907},"B78",{"#text":3909},"). To calculate this, respondents will be grouped into three groups—high, middle, and lower tertiles based on their total scores on a set of items. Items will be regarded as appropriate if 100% of those in the high group choose the correct response options, about 50% of those in the middle choose the correct option, and few or none in the lower group choose the correct option (",{"xref":3911,":@":3913},[3912],{"#text":3905},{"@_ref-type":898,"@_rid":3907},{"#text":3915},"). This type of analysis is rarely used in the health sciences, as most multiple-choice items are on a Likert-type response scale and do not test respondent correct knowledge, but their experience or perception. However, distractor analysis can help to determine whether items are well-constructed, meaningful, and functional when researchers add response options to questions that do not fit a particular experience. It is expected that participants who are determined as having poor knowledge or experience on the construct will choose the distractors, while those with the right knowledge and experience will choose the correct response options (",{"xref":3917,":@":3919},[3918],{"#text":1813},{"@_ref-type":898,"@_rid":1815},{"#text":933},{"xref":3922,":@":3925},[3923],{"#text":3924},"79",{"@_ref-type":898,"@_rid":3926},"B79",{"#text":3928},"). Where those with the right knowledge and experience are not able to differentiate between distractors and the right response, the question may have to be modified. Non-functional distractors identified need to be removed and replaced with efficient distractors (",{"xref":3930,":@":3932},[3931],{"#text":1820},{"@_ref-type":898,"@_rid":1822},{"#text":941},{"#text":802},{"#text":802},{"sec":3937},[3938,3939,3943,3944,3986],{"#text":796},{"title":3940},[3941],{"#text":3942},"Missing cases",{"#text":796},{"p":3945},[3946,3948,3952,3954,3960,3962,3968,3970,3973,3975,3979,3981,3985],{"#text":3947},"In addition to these techniques, some researchers opt to delete items with large numbers of cases that are missing, when other missing data-handling techniques cannot be used (",{"xref":3949,":@":3951},[3950],{"#text":1854},{"@_ref-type":898,"@_rid":1856},{"#text":3953},"). For cases where modern missing data handling can be used, however, several techniques exist to solve the problem of missing cases. Two of the approaches have proven to be very useful for scale development: full information maximum likelihood (FIML) (",{"xref":3955,":@":3958},[3956],{"#text":3957},"82",{"@_ref-type":898,"@_rid":3959},"B82",{"#text":3961},") and multiple imputation (",{"xref":3963,":@":3966},[3964],{"#text":3965},"83",{"@_ref-type":898,"@_rid":3967},"B83",{"#text":3969},"). Both methods can be applied using existing commands in statistical packages such as M",{"italic":3971},[3972],{"#text":3686},{"#text":3974},", R, SAS, and Stata. When using multiple imputation to recover missing data in the context of survey research, the researcher can impute individual items prior to computing scale scores or impute the scale scores from other scale scores (",{"xref":3976,":@":3978},[3977],{"#text":1861},{"@_ref-type":898,"@_rid":1863},{"#text":3980},"). However, item-level imputation has been shown to produce more efficient estimates over scale-level imputation. Thus, imputing individual items before scale development is a preferred approach to imputing newly developed scales for missing cases (",{"xref":3982,":@":3984},[3983],{"#text":1861},{"@_ref-type":898,"@_rid":1863},{"#text":941},{"#text":802},{"#text":877},{"#text":877},{"sec":3990},[3991,3992,3996,3997,4018,4019,4065,4066,4086,4087,4097],{"#text":802},{"title":3993},[3994],{"#text":3995},"Step 6: extraction of factors",{"#text":802},{"p":3998},[3999,4001,4005,4007,4011,4013,4017],{"#text":4000},"Factor extraction is the phase in which the optimal number of factors, sometimes called domains, that fit a set of items are determined. This is done using factor analysis. Factor analysis is a regression model in which observed standardized variables are regressed on unobserved (i.e., latent) factors. Because the variables and factors are standardized, the bivariate regression coefficients are also correlations, representing the loading of each observed variable on each factor. Thus, factor analysis is used to understand the latent (internal) structure of a set of items, and the extent to which the relationships between the items are internally consistent (",{"xref":4002,":@":4004},[4003],{"#text":1198},{"@_ref-type":898,"@_rid":1200},{"#text":4006},"). This is done by extracting latent factors which represent the shared variance in responses among the multiple items (",{"xref":4008,":@":4010},[4009],{"#text":1198},{"@_ref-type":898,"@_rid":1200},{"#text":4012},"). The emphasis is on the number of factors, the salience of factor loading estimates, and the relative magnitude of residual variances (",{"xref":4014,":@":4016},[4015],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":941},{"#text":802},{"p":4020},[4021,4023,4027,4029,4033,4035,4041,4043,4049,4051,4057,4058,4064],{"#text":4022},"A number of analytical processes have been used to determine the number of factors to retain from a list of items, and it is beyond the scope of this paper to describe all of them. For scale development, commonly available methods to determine the number of factors to retain include a scree plot (",{"xref":4024,":@":4026},[4025],{"#text":1930},{"@_ref-type":898,"@_rid":1932},{"#text":4028},"), the variance explained by the factor model, and the pattern of factor loadings (",{"xref":4030,":@":4032},[4031],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":4034},"). Where feasible, researchers could also assess the optimal number of factors to be drawn from the list of items using either parallel analysis (",{"xref":4036,":@":4039},[4037],{"#text":4038},"86",{"@_ref-type":898,"@_rid":4040},"B86",{"#text":4042},"), minimum average partial procedure (",{"xref":4044,":@":4047},[4045],{"#text":4046},"87",{"@_ref-type":898,"@_rid":4048},"B87",{"#text":4050},"), or the Hull method (",{"xref":4052,":@":4055},[4053],{"#text":4054},"88",{"@_ref-type":898,"@_rid":4056},"B88",{"#text":933},{"xref":4059,":@":4062},[4060],{"#text":4061},"89",{"@_ref-type":898,"@_rid":4063},"B89",{"#text":941},{"#text":802},{"p":4067},[4068,4070,4074,4075,4079,4081,4085],{"#text":4069},"The extraction of factors can also be used to reduce items. With factor analysis, items with factor loadings or slope coefficients that are below 0.30 are considered inadequate as they contribute \u003C10% variation of the latent construct measured. Hence, it is often recommended to retain items that have factor loadings of 0.40 and above (",{"xref":4071,":@":4073},[4072],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":4076,":@":4078},[4077],{"#text":3402},{"@_ref-type":898,"@_rid":3404},{"#text":4080},"). Also, items with cross-loadings or that appear not to load uniquely on individual factors can be deleted. For single-factor models in which Rasch IRT modeling is used, items are selected as having a good fit based on mean-square residual summary statistics (infit and outfit) >0.4 and \u003C1.6 (",{"xref":4082,":@":4084},[4083],{"#text":1937},{"@_ref-type":898,"@_rid":1939},{"#text":941},{"#text":802},{"p":4088},[4089,4091,4095],{"#text":4090},"A number of scales developed stop at this phase and jump to tests of reliability, but the factors extracted at this point only provide a ",{"italic":4092},[4093],{"#text":4094},"hypothetical",{"#text":4096}," structure of the scale. The dimensionality of these factors need to be tested (cf. Step 7) before moving on to reliability (cf. Step 8) and validity (cf. Step 9) assessment.",{"#text":877},{"#text":880},{"@_id":4100},"s4",{"#text":880},{"sec":4103,":@":5300,"anchorId":5301},[4104,4105,4109,4110,4843,4844,5050,5051,5299],{"#text":877},{"title":4106},[4107],{"#text":4108},"Phase 3: scale evaluation",{"#text":877},{"sec":4111},[4112,4113,4117,4118,4128,4129,4551,4552,4668,4669,4805,4806,4842],{"#text":802},{"title":4114},[4115],{"#text":4116},"Step 7: tests of dimensionality",{"#text":802},{"p":4119},[4120,4122,4126],{"#text":4121},"The test of dimensionality is a test in which the hypothesized factors or factor structure extracted from a previous model is tested at a different time point in a longitudinal study or, ideally, on a new sample (",{"xref":4123,":@":4125},[4124],{"#text":2023},{"@_ref-type":898,"@_rid":2025},{"#text":4127},"). Tests of dimensionality determine whether the measurement of items, their factors, and function are the same across two independent samples or within the same sample at different time points. Such tests can be conducted using independent cluster model (ICM)-confirmatory factor analysis, bifactor modeling, or measurement invariance.",{"#text":802},{"sec":4130},[4131,4132,4136,4137,4183,4184,4550],{"#text":796},{"title":4133},[4134],{"#text":4135},"Confirmatory factor analysis",{"#text":796},{"p":4138},[4139,4141,4144,4146,4152,4154,4158,4160,4164,4166,4170,4171,4175,4176,4182],{"#text":4140},"Confirmatory factor analysis is a form of psychometric assessment that allows for the systematic comparison of an alternative ",{"italic":4142},[4143],{"#text":1179},{"#text":4145}," factor structure based on systematic fit assessment procedures and estimates the relationship between latent constructs, which have been corrected for measurement errors (",{"xref":4147,":@":4150},[4148],{"#text":4149},"92",{"@_ref-type":898,"@_rid":4151},"B92",{"#text":4153},"). Morin et al. (",{"xref":4155,":@":4157},[4156],{"#text":4149},{"@_ref-type":898,"@_rid":4151},{"#text":4159},") note that it relies on a highly restrictive ICM, in which cross-loadings between items and non-target factors are assumed to be exactly zero. The systematic fit assessment procedures are determined by meaningful satisfactory thresholds; Table ",{"xref":4161,":@":4163},[4162],{"#text":1245},{"@_ref-type":2005,"@_rid":2006},{"#text":4165}," contains the most common techniques for testing dimensionality. These techniques include the chi-square test of exact fit, Root Mean Square Error of Approximation (RMSEA ≤ 0.06), Tucker Lewis Index (TLI ≥ 0.95), Comparative Fit Index (CFI ≥ 0.95), Standardized Root Mean Square Residual (SRMR ≤ 0.08), and Weighted Root Mean Square Residual (WRMR ≤ 1.0) (",{"xref":4167,":@":4169},[4168],{"#text":1937},{"@_ref-type":898,"@_rid":1939},{"#text":933},{"xref":4172,":@":4174},[4173],{"#text":4149},{"@_ref-type":898,"@_rid":4151},{"#text":917},{"xref":4177,":@":4180},[4178],{"#text":4179},"101",{"@_ref-type":898,"@_rid":4181},"B101",{"#text":941},{"#text":796},{"table-wrap":4185,":@":4549},[4186,4187,4191,4192,4200,4201,4548],{"#text":1053},{"label":4188},[4189],{"#text":4190},"Table 2",{"#text":1053},{"caption":4193},[4194,4195,4199],{"#text":1057},{"p":4196},[4197],{"#text":4198},"Description of model fit indices and thresholds for evaluating scales developed for health, social, and behavioral research.",{"#text":1053},{"#text":1053},{"table":4202,":@":4547},[4203,4204,4252,4253,4546],{"#text":1057},{"thead":4205},[4206,4207,4251],{"#text":1061},{"tr":4208},[4209,4211,4221,4222,4231,4232,4241,4242,4250],{"#text":4210},"\n                  ",{"th":4212,":@":4220},[4213,4215,4219],{"#text":4214},"\n                    ",{"bold":4216},[4217],{"#text":4218},"Model fit indices",{"#text":4210},{"@_valign":1068,"@_align":1069},{"#text":4210},{"th":4223,":@":4230},[4224,4225,4229],{"#text":4214},{"bold":4226},[4227],{"#text":4228},"Description",{"#text":4210},{"@_valign":1068,"@_align":1069},{"#text":4210},{"th":4233,":@":4240},[4234,4235,4239],{"#text":4214},{"bold":4236},[4237],{"#text":4238},"Recommended threshold to use",{"#text":4210},{"@_valign":1068,"@_align":1069},{"#text":4210},{"th":4243,":@":4249},[4244,4245,4248],{"#text":4214},{"bold":4246},[4247],{"#text":1097},{"#text":4210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1057},{"#text":1057},{"tbody":4254},[4255,4256,4300,4301,4353,4354,4394,4395,4431,4432,4468,4469,4506,4507,4545],{"#text":1061},{"tr":4257},[4258,4259,4264,4265,4270,4271,4282,4283,4299],{"#text":4210},{"td":4260,":@":4263},[4261],{"#text":4262},"Chi-square test",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4266,":@":4269},[4267],{"#text":4268},"The chi-square value is a test statistic of the goodness of fit of a factor model. It compares the observed covariance matrix with a theoretically proposed covariance matrix",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4272,":@":4281},[4273,4275,4279],{"#text":4274},"Chi-square test of model fit has been assessed to be overly sensitive to sample size and to vary when dealing with non-normal variables. Hence, the use of non-normal data, a small sample size (",{"italic":4276},[4277],{"#text":4278},"n",{"#text":4280}," = 180–300), and highly correlated items make the chi-square approximation inaccurate. An alternative to this is to use the Satorra-Bentler scaled (mean-adjusted) difference chi-squared statistic. The DIFFTEST has been recommended for models with binary and ordinal variables",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4284,":@":4298},[4285,4286,4290,4291,4297],{"#text":1189},{"xref":4287,":@":4289},[4288],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":4292,":@":4295},[4293],{"#text":4294},"93",{"@_ref-type":898,"@_rid":4296},"B93",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1061},{"tr":4302},[4303,4304,4309,4310,4322,4323,4328,4329,4352],{"#text":4210},{"td":4305,":@":4308},[4306],{"#text":4307},"Root Mean Squared Error of Approximation (RMSEA)",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4311,":@":4321},[4312,4314,4320],{"#text":4313},"RMSEA is a measure of the estimated discrepancy between the population and model-implied population covariance matrices per degree of freedom (",{"xref":4315,":@":4318},[4316],{"#text":4317},"139",{"@_ref-type":898,"@_rid":4319},"B139",{"#text":941},{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4324,":@":4327},[4325],{"#text":4326},"Browne and Cudeck recommend RMSEA ≤ 0.05 as indicative of close fit, 0.05 ≤ RMSEA ≤ 0.08 as indicative of fair fit, and values >0.10 as indicative of poor fit between the hypothesized model and the observed data. However, Hu and Bentler have suggested RMSEA ≤ 0.06 may indicate a good fit",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4330,":@":4351},[4331,4332,4336,4337,4343,4344,4350],{"#text":1189},{"xref":4333,":@":4335},[4334],{"#text":2596},{"@_ref-type":898,"@_rid":2598},{"#text":933},{"xref":4338,":@":4341},[4339],{"#text":4340},"96",{"@_ref-type":898,"@_rid":4342},"B96",{"#text":917},{"xref":4345,":@":4348},[4346],{"#text":4347},"100",{"@_ref-type":898,"@_rid":4349},"B100",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1061},{"tr":4355},[4356,4357,4362,4363,4368,4369,4374,4375,4393],{"#text":4210},{"td":4358,":@":4361},[4359],{"#text":4360},"Tucker Lewis Index (TLI)",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4364,":@":4367},[4365],{"#text":4366},"TLI is based on the idea of comparing the proposed factor model to a model in which no interrelationships at all are assumed among any of the items",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4370,":@":4373},[4371],{"#text":4372},"Bentler and Bonnett suggest that models with overall fit indices of \u003C 0.90 are generally inadequate and can be improved substantially. Hu and Bentler recommend TLI ≥ 0.95",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4376,":@":4392},[4377,4378,4384,4385,4391],{"#text":1189},{"xref":4379,":@":4382},[4380],{"#text":4381},"95",{"@_ref-type":898,"@_rid":4383},"B95",{"#text":917},{"xref":4386,":@":4389},[4387],{"#text":4388},"98",{"@_ref-type":898,"@_rid":4390},"B98",{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1061},{"tr":4396},[4397,4398,4403,4404,4409,4410,4415,4416,4430],{"#text":4210},{"td":4399,":@":4402},[4400],{"#text":4401},"Comparative Fit Index (CFI)",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4405,":@":4408},[4406],{"#text":4407},"CFI is an incremental relative fit index that measures the relative improvement in the fit of a researcher's model over that of a baseline model",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4411,":@":4414},[4412],{"#text":4413},"CFI ≥ 0.95 is often considered an acceptable fit",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4417,":@":4429},[4418,4419,4423,4424,4428],{"#text":1189},{"xref":4420,":@":4422},[4421],{"#text":4381},{"@_ref-type":898,"@_rid":4383},{"#text":917},{"xref":4425,":@":4427},[4426],{"#text":4388},{"@_ref-type":898,"@_rid":4390},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1061},{"tr":4433},[4434,4435,4440,4441,4446,4447,4452,4453,4467],{"#text":4210},{"td":4436,":@":4439},[4437],{"#text":4438},"Standardized Root Mean Square Residual (SRMR)",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4442,":@":4445},[4443],{"#text":4444},"SRMR is a measure of the mean absolute correlation residual, the overall difference between the observed and predicted correlations",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4448,":@":4451},[4449],{"#text":4450},"Threshold for acceptable model fit is SRMR ≤ 0.08",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4454,":@":4466},[4455,4456,4460,4461,4465],{"#text":1189},{"xref":4457,":@":4459},[4458],{"#text":4381},{"@_ref-type":898,"@_rid":4383},{"#text":917},{"xref":4462,":@":4464},[4463],{"#text":4388},{"@_ref-type":898,"@_rid":4390},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1061},{"tr":4470},[4471,4472,4477,4478,4489,4490,4495,4496,4505],{"#text":4210},{"td":4473,":@":4476},[4474],{"#text":4475},"Weighted Root Mean Square Residual (WRMR)",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4479,":@":4488},[4480,4482,4486],{"#text":4481},"WRMR uses a “variance-weighted approach especially suited for models whose variables measured on different scales or have widely unequal variances” (",{"xref":4483,":@":4485},[4484],{"#text":4317},{"@_ref-type":898,"@_rid":4319},{"#text":4487},"); it has been assessed to be most suitable in assessing models fitted to binary and ordinal data",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4491,":@":4494},[4492],{"#text":4493},"Yu recommends a threshold of WRMR \u003C 1.0 for assessing model fit. This index is used for confirmatory factor analysis and structural equation models with binary and ordinal variables",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4497,":@":4504},[4498,4499,4503],{"#text":1189},{"xref":4500,":@":4502},[4501],{"#text":4179},{"@_ref-type":898,"@_rid":4181},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1061},{"tr":4508},[4509,4510,4515,4516,4521,4522,4527,4528,4544],{"#text":4210},{"td":4511,":@":4514},[4512],{"#text":4513},"Standard of Reliability for scales",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4517,":@":4520},[4518],{"#text":4519},"A reliability of 0.90 is the minimum recommended threshold that should be tolerated while a reliability of 0.95 should be the desirable standard. While the ideal has rarely been attained by most researchers, a reliability coefficient of 0.70 has often been accepted as satisfactory for most scales",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4523,":@":4526},[4524],{"#text":4525},"Nunnally recommends a threshold of ≥0.90 for assessing internal consistency for scales",{"@_valign":1068,"@_align":1069},{"#text":4210},{"td":4529,":@":4543},[4530,4531,4537,4538,4542],{"#text":1189},{"xref":4532,":@":4535},[4533],{"#text":4534},"117",{"@_ref-type":898,"@_rid":4536},"B117",{"#text":933},{"xref":4539,":@":4541},[4540],{"#text":2138},{"@_ref-type":898,"@_rid":2140},{"#text":1210},{"@_valign":1068,"@_align":1069},{"#text":1061},{"#text":1057},{"#text":1053},{"@_frame":2505,"@_rules":2506},{"#text":796},{"@_position":1023,"@_id":2006},{"#text":802},{"#text":802},{"sec":4553},[4554,4555,4559,4560,4667],{"#text":796},{"title":4556},[4557],{"#text":4558},"Bifactor modeling",{"#text":796},{"p":4561},[4562,4564,4570,4571,4577,4579,4585,4586,4592,4594,4598,4600,4604,4606,4609,4611,4614,4616,4620,4622,4626,4627,4631,4633,4637,4638,4644,4646,4650,4651,4655,4657,4661,4663,4666],{"#text":4563},"Bifactor modeling, also referred to as nested factor modeling, is a form of item response theory used in testing dimensionality of a scale (",{"xref":4565,":@":4568},[4566],{"#text":4567},"102",{"@_ref-type":898,"@_rid":4569},"B102",{"#text":933},{"xref":4572,":@":4575},[4573],{"#text":4574},"103",{"@_ref-type":898,"@_rid":4576},"B103",{"#text":4578},"). This method can be used when the hypothesized factor structure from the previous model produces partially overlapping dimensions so that one could be seeing most of the items loading onto one factor and a few items loading onto a second and/or a third factor. The bifactor model allows researchers to estimate a unidimensional construct while recognizing the multidimensionality of the construct (",{"xref":4580,":@":4583},[4581],{"#text":4582},"104",{"@_ref-type":898,"@_rid":4584},"B104",{"#text":933},{"xref":4587,":@":4590},[4588],{"#text":4589},"105",{"@_ref-type":898,"@_rid":4591},"B105",{"#text":4593},"). The bifactor model assumes each item loads onto two dimensions, i.e., items forming the construct may be associated with more than one source of true score variance (",{"xref":4595,":@":4597},[4596],{"#text":4149},{"@_ref-type":898,"@_rid":4151},{"#text":4599},"). The first is a general latent factor that underlies all the scale items and the second, a group factor (subscale). A “bifactor model is based on the assumption that a ",{"italic":4601},[4602],{"#text":4603},"f",{"#text":4605},"-factor solution exists for a set of ",{"italic":4607},[4608],{"#text":4278},{"#text":4610}," items with one [general]/Global (G) factor and ",{"italic":4612},[4613],{"#text":4603},{"#text":4615}," – 1 Specific (S) factors also called group factors” (",{"xref":4617,":@":4619},[4618],{"#text":4149},{"@_ref-type":898,"@_rid":4151},{"#text":4621},"). This approach allows researchers to examine any distortion that may occur when unidimensional IRT models are fit to multidimensional data (",{"xref":4623,":@":4625},[4624],{"#text":4582},{"@_ref-type":898,"@_rid":4584},{"#text":933},{"xref":4628,":@":4630},[4629],{"#text":4589},{"@_ref-type":898,"@_rid":4591},{"#text":4632},"). To determine whether to retain a construct as unidimensional or multidimensional, the factor loadings from the general factor are then compared to those from the group factors (",{"xref":4634,":@":4636},[4635],{"#text":4574},{"@_ref-type":898,"@_rid":4576},{"#text":933},{"xref":4639,":@":4642},[4640],{"#text":4641},"106",{"@_ref-type":898,"@_rid":4643},"B106",{"#text":4645},"). Where the factor loadings on the general factor are significantly larger than the group factors, a unidimensional scale is implied (",{"xref":4647,":@":4649},[4648],{"#text":4574},{"@_ref-type":898,"@_rid":4576},{"#text":933},{"xref":4652,":@":4654},[4653],{"#text":4582},{"@_ref-type":898,"@_rid":4584},{"#text":4656},"). This method is assessed based on meaningful satisfactory thresholds. Alternatively, one can test for the coexistence of a general factor that underlies the construct and multiple group factors that explain the remaining variance not explained by the general factor (",{"xref":4658,":@":4660},[4659],{"#text":4149},{"@_ref-type":898,"@_rid":4151},{"#text":4662},"). Each of these methods can be done using statistical software such as M",{"italic":4664},[4665],{"#text":3686},{"#text":3688},{"#text":802},{"#text":802},{"sec":4670},[4671,4672,4676,4677,4735,4736,4763,4764,4774,4775,4788,4789,4804],{"#text":796},{"title":4673},[4674],{"#text":4675},"Measurement invariance",{"#text":796},{"p":4678},[4679,4681,4687,4689,4695,4697,4701,4702,4708,4710,4714,4715,4719,4721,4727,4728,4734],{"#text":4680},"Another method to test dimensionality is measurement invariance, also referred to as factorial invariance or measurement equivalence (",{"xref":4682,":@":4685},[4683],{"#text":4684},"107",{"@_ref-type":898,"@_rid":4686},"B107",{"#text":4688},"). Measurement invariance concerns the extent to which the psychometric properties of the observed indicators are transportable (generalizable) across groups or over time (",{"xref":4690,":@":4693},[4691],{"#text":4692},"108",{"@_ref-type":898,"@_rid":4694},"B108",{"#text":4696},"). These properties include the hypothesized factor structure, regression slopes, intercept, and residual variances. Measurement invariance is tested sequentially at five levels—configural, metric, scalar, strict (residual), and structural (",{"xref":4698,":@":4700},[4699],{"#text":4684},{"@_ref-type":898,"@_rid":4686},{"#text":933},{"xref":4703,":@":4706},[4704],{"#text":4705},"109",{"@_ref-type":898,"@_rid":4707},"B109",{"#text":4709},"). Of key significance to the test of dimensionality is configural invariance, which is concerned with whether the hypothesized factor structure is the same across groups. This assumption has to be met in order for subsequent tests to be meaningful (",{"xref":4711,":@":4713},[4712],{"#text":4684},{"@_ref-type":898,"@_rid":4686},{"#text":933},{"xref":4716,":@":4718},[4717],{"#text":4705},{"@_ref-type":898,"@_rid":4707},{"#text":4720},"). For example, a hypothesized unidimensional structure, when tested across multiple countries, should be the same. This can be tested in CTT, using multigroup confirmatory factor analysis (",{"xref":4722,":@":4725},[4723],{"#text":4724},"110",{"@_ref-type":898,"@_rid":4726},"B110",{"#text":917},{"xref":4729,":@":4732},[4730],{"#text":4731},"112",{"@_ref-type":898,"@_rid":4733},"B112",{"#text":941},{"#text":796},{"p":4737},[4738,4740,4744,4745,4751,4753,4757,4758,4762],{"#text":4739},"An alternative approach to measurement invariance in the testing of unidimensionality under item response theory is the Rasch measurement model for binary items and polytomous IRT models for categorical items. Here, emphasis is on testing the differential item functioning (DIF)—an indicator of whether “a group of respondents is scoring better than another group of respondents on an item or a test after adjusting for the overall ability scores of the respondents” (",{"xref":4741,":@":4743},[4742],{"#text":4692},{"@_ref-type":898,"@_rid":4694},{"#text":933},{"xref":4746,":@":4749},[4747],{"#text":4748},"113",{"@_ref-type":898,"@_rid":4750},"B113",{"#text":4752},"). This is analogous to the conditions underpinning measurement invariance in a multi-group CFA (",{"xref":4754,":@":4756},[4755],{"#text":4692},{"@_ref-type":898,"@_rid":4694},{"#text":933},{"xref":4759,":@":4761},[4760],{"#text":4748},{"@_ref-type":898,"@_rid":4750},{"#text":941},{"#text":796},{"p":4765},[4766,4768,4772],{"#text":4767},"Whether the hypothesized structure is bidimensional or multidimensional, each dimension in the structure needs to be tested again to confirm its unidimensionality. This can also be done using confirmatory factor analysis. Appropriate model fit indices and the strength of factor loadings (cf. Table ",{"xref":4769,":@":4771},[4770],{"#text":1245},{"@_ref-type":2005,"@_rid":2006},{"#text":4773},") are the basis on which the latent structure of the items can be judged.",{"#text":796},{"p":4776},[4777,4779,4782,4784,4787],{"#text":4778},"One commonly encountered pitfall is a lack of satisfactory global model fit in confirmatory factor analysis conducted on a new sample following a satisfactory initial factor analysis performed on a previous sample. Lack of satisfactory fit offers the opportunity to identify additional underperforming items for removal. Items with very poor loadings (≤0.3) can be considered for removal. Also, modification indices, produced by M",{"italic":4780},[4781],{"#text":3686},{"#text":4783}," and other structural equation modeling (SEM) programs, can help identify items that need to be modified. Sometimes a higher-order factor structure, where correlations among the original factors can be explained by one or more higher-order factors, is needed. This can also be assessed using statistical software such as M",{"italic":4785},[4786],{"#text":3686},{"#text":3688},{"#text":796},{"p":4790},[4791,4793,4797,4799,4803],{"#text":4792},"A good example of best practice is seen in the work of Pushpanathan et al. on the appropriateness of using a traditional confirmatory factor analysis or a bifactor model (",{"xref":4794,":@":4796},[4795],{"#text":2030},{"@_ref-type":898,"@_rid":2032},{"#text":4798},") in assessing whether the Parkinson's Disease Sleep Scale-Revised was better used as a unidimensional scale, a tri-dimensional scale, or a scale that has an underlying general factor and three group factors (sub-scales). They tested this using three different models—a unidimensional model (1-factor CFA); a 3-factor model (3 factor CFA) consisting of sub-scales measuring insomnia, motor symptoms and obstructive sleep apnea, and REM sleep behavior disorder; and a confirmatory bifactor model having a general factor and the same three sub-scales combined. The results of this study suggested that only the bifactor model with a general factor and the three sub-scales combined achieved satisfactory model fitness. Based on these results, the authors cautioned against the use of a unidimensional total scale scores as a cardinal indicator of sleep in Parkinson's disease, but encouraged the examination of its multidimensional subscales (",{"xref":4800,":@":4802},[4801],{"#text":2030},{"@_ref-type":898,"@_rid":2032},{"#text":941},{"#text":802},{"#text":802},{"sec":4807},[4808,4809,4813,4814,4841],{"#text":796},{"title":4810},[4811],{"#text":4812},"Scoring scale items",{"#text":796},{"p":4815},[4816,4818,4822,4824,4827,4829,4833,4835,4839],{"#text":4817},"Finalized items from the tests of dimensionality can be used to create scale scores for substantive analysis including tests of reliability and validity. Scale scores can be calculated by using unweighted or weighted procedures. The unweighted approach involves summing standardized item scores or raw item scores, or computing the mean for raw item scores (",{"xref":4819,":@":4821},[4820],{"#text":2068},{"@_ref-type":898,"@_rid":2070},{"#text":4823},"). The weighted approach in calculating scale scores can be produced via statistical software programs such as M",{"italic":4825},[4826],{"#text":3686},{"#text":4828},", R, SAS, SPSS, or Stata. For instance, in using confirmatory factor analysis, structural equation models, or exploratory factor analysis, each factor produced reveals a statistically independent source of variation among a set of items (",{"xref":4830,":@":4832},[4831],{"#text":2068},{"@_ref-type":898,"@_rid":2070},{"#text":4834},"). The contribution of each individual item to this factor is considered a weight, with the factor loading value representing the weight. The scores associated with each factor in a model then represents a composite scale score based on a weighted sum of the individual items using factor loadings (",{"xref":4836,":@":4838},[4837],{"#text":2068},{"@_ref-type":898,"@_rid":2070},{"#text":4840},"). In general, it does not make much difference in the performance of the scale if scales are computed as unweighted items (e.g., mean or sum scores) or weighted items (e.g., factor scores).",{"#text":802},{"#text":877},{"#text":877},{"sec":4845},[4846,4847,4851,4852,4944,4945,4990,4991,5049],{"#text":802},{"title":4848},[4849],{"#text":4850},"Step 8: tests of reliability",{"#text":802},{"p":4853},[4854,4856,4860,4862,4866,4868,4874,4875,4881,4883,4887,4888,4892,4894,4900,4902,4906,4908,4914,4915,4921,4923,4927,4928,4932,4934,4938,4939,4943],{"#text":4855},"Reliability is the degree of consistency exhibited when a measurement is repeated under identical conditions (",{"xref":4857,":@":4859},[4858],{"#text":2131},{"@_ref-type":898,"@_rid":2133},{"#text":4861},"). A number of standard statistics have been developed to assess reliability of a scale, including Cronbach's alpha (",{"xref":4863,":@":4865},[4864],{"#text":4534},{"@_ref-type":898,"@_rid":4536},{"#text":4867},"), ordinal alpha (",{"xref":4869,":@":4872},[4870],{"#text":4871},"118",{"@_ref-type":898,"@_rid":4873},"B118",{"#text":933},{"xref":4876,":@":4879},[4877],{"#text":4878},"119",{"@_ref-type":898,"@_rid":4880},"B119",{"#text":4882},") specific to binary and ordinal scale items, test–retest reliability (coefficient of stability) (",{"xref":4884,":@":4886},[4885],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":4889,":@":4891},[4890],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":4893},"), McDonald's Omega (",{"xref":4895,":@":4898},[4896],{"#text":4897},"120",{"@_ref-type":898,"@_rid":4899},"B120",{"#text":4901},"), Raykov's rho (",{"xref":4903,":@":4905},[4904],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":4907},") or Revelle's beta (",{"xref":4909,":@":4912},[4910],{"#text":4911},"121",{"@_ref-type":898,"@_rid":4913},"B121",{"#text":933},{"xref":4916,":@":4919},[4917],{"#text":4918},"122",{"@_ref-type":898,"@_rid":4920},"B122",{"#text":4922},"), split-half estimates, Spearman-Brown formula, alternate form method (coefficient of equivalence), and inter-observer reliability (",{"xref":4924,":@":4926},[4925],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":4929,":@":4931},[4930],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":4933},"). Of these statistics, Cronbach's alpha and test–retest reliability are predominantly used to assess reliability of scales (",{"xref":4935,":@":4937},[4936],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":4940,":@":4942},[4941],{"#text":4534},{"@_ref-type":898,"@_rid":4536},{"#text":941},{"#text":802},{"sec":4946},[4947,4948,4952,4953,4989],{"#text":796},{"title":4949},[4950],{"#text":4951},"Cronbach's alpha",{"#text":796},{"p":4954},[4955,4957,4961,4962,4966,4967,4971,4973,4977,4978,4982,4983,4987],{"#text":4956},"Cronbach's alpha assesses the internal consistency of the scale items, i.e., the degree to which the set of items in the scale co-vary, relative to their sum score (",{"xref":4958,":@":4960},[4959],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":4963,":@":4965},[4964],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":4968,":@":4970},[4969],{"#text":4534},{"@_ref-type":898,"@_rid":4536},{"#text":4972},"). An alpha coefficient of 0.70 has often been regarded as an acceptable threshold for reliability; however, 0.80 and 0.95 is preferred for the psychometric quality of scales (",{"xref":4974,":@":4976},[4975],{"#text":3402},{"@_ref-type":898,"@_rid":3404},{"#text":933},{"xref":4979,":@":4981},[4980],{"#text":4534},{"@_ref-type":898,"@_rid":4536},{"#text":933},{"xref":4984,":@":4986},[4985],{"#text":2138},{"@_ref-type":898,"@_rid":2140},{"#text":4988},"). Cronbach's alpha has been the most common and seems to have received general approval; however, reliability statistics such as Raykov's rho, ordinal alpha, and Revelle's beta, which are debated to have improvements over Cronbach's alpha, are beginning to gain acceptance.",{"#text":802},{"#text":802},{"sec":4992},[4993,4994,4997,4998,5020,5021,5033,5034,5048],{"#text":796},{"title":4995},[4996],{"#text":2151},{"#text":796},{"p":4999},[5000,5002,5006,5008,5012,5014,5018],{"#text":5001},"An additional approach in testing reliability is the test–retest reliability. The test–retest reliability, also known as the coefficient of stability, is used to assess the degree to which the participants' performance is repeatable, i.e., how consistent their sum scores are across time (",{"xref":5003,":@":5005},[5004],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5007},"). Researchers vary in how they assess test–retest reliability. While some prefer to use intra class correlation coefficient (",{"xref":5009,":@":5011},[5010],{"#text":2182},{"@_ref-type":898,"@_rid":2184},{"#text":5013},"), others use the Pearson product-moment correlation (",{"xref":5015,":@":5017},[5016],{"#text":2189},{"@_ref-type":898,"@_rid":2191},{"#text":5019},"). In both cases, the higher the correlation, the higher the test–retest reliability, with values close to zero indicating low reliability. In addition, study conditions could change values on the construct being measured over time (as in an intervention study, for example), which could lower the test-retest reliability.",{"#text":796},{"p":5022},[5023,5025,5031],{"#text":5024},"The work of Johnson et al. (",{"xref":5026,":@":5029},[5027],{"#text":5028},"16",{"@_ref-type":898,"@_rid":5030},"B16",{"#text":5032},") on the validation of the HIV Treatment Adherence Self-Efficacy Scale (ASES) is a good example of the test of reliability. As part of testing for reliability, the authors tested for the internal consistency reliability values for the ASES and its subscales using Raykov's rho (produces a coefficient similar to alpha but with fewer assumptions and with confidence intervals); they then tested for the temporal consistency of the ASES' factor structure. This was then followed by test–retest reliability assessment among the latent factors. The different approaches provided support for the reliability of the ASES scale.",{"#text":796},{"p":5035},[5036,5038,5042,5043,5047],{"#text":5037},"Other approaches found to be useful and support scale reliability include split-half estimates, Spearman-Brown formula, alternate form method (coefficient of equivalence), and inter-observer reliability (",{"xref":5039,":@":5041},[5040],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":5044,":@":5046},[5045],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":941},{"#text":802},{"#text":877},{"#text":877},{"sec":5052},[5053,5054,5058,5059,5075,5076,5141,5142,5298],{"#text":802},{"title":5055},[5056],{"#text":5057},"Step 9: tests of validity",{"#text":802},{"p":5060},[5061,5063,5067,5069,5073],{"#text":5062},"Scale validity is the extent to which “an instrument indeed measures the latent dimension or construct it was developed to evaluate” (",{"xref":5064,":@":5066},[5065],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5068},"). Although it is discussed at length here in Step 9, validation is an ongoing process that starts with the identification and definition of the domain of study (Step 1) and continues to its generalizability with other constructs (Step 9) (",{"xref":5070,":@":5072},[5071],{"#text":2836},{"@_ref-type":898,"@_rid":2838},{"#text":5074},"). The validity of an instrument can be examined in numerous ways; the most common tests of validity are content validity (described in Step 2), which can be done prior to the instrument being administered to the target population, and criterion (predictive and concurrent) and construct validity (convergent, discriminant, differentiation by known groups, correlations), which occurs after survey administration.",{"#text":802},{"sec":5077},[5078,5079,5082,5083,5110,5111,5129,5130,5140],{"#text":796},{"title":5080},[5081],{"#text":2230},{"#text":796},{"p":5084},[5085,5087,5091,5092,5096,5098,5102,5104,5108],{"#text":5086},"Criterion validity is the “degree to which there is a relationship between a given test score and performance on another measure of particular relevance, typically referred to as criterion” (",{"xref":5088,":@":5090},[5089],{"#text":896},{"@_ref-type":898,"@_rid":899},{"#text":933},{"xref":5093,":@":5095},[5094],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5097},"). There are two forms of criterion validity: predictive (criterion) validity and concurrent (criterion) validity. Predictive validity is “the extent to which a measure predicts the answers to some other question or a result to which it ought to be related with” (",{"xref":5099,":@":5101},[5100],{"#text":2272},{"@_ref-type":898,"@_rid":2274},{"#text":5103},"). Thus, the scale should be able to predict a behavior in the future. An example is the ability for an exclusive breastfeeding social support scale to predict exclusive breastfeeding (",{"xref":5105,":@":5107},[5106],{"#text":950},{"@_ref-type":898,"@_rid":952},{"#text":5109},"). Here, the mother's willingness to exclusively breastfeed occurs after social support has been given, i.e., it should predict the behavior. Predictive validity can be estimated by examining the association between the scale scores and the criterion in question.",{"#text":796},{"p":5112},[5113,5115,5119,5121,5127],{"#text":5114},"Concurrent criterion validity is the extent to which test scores have a stronger relationship with criterion (gold standard) measurement made at the time of test administration or shortly afterward (",{"xref":5116,":@":5118},[5117],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5120},"). This can be estimated using Pearson product-moment correlation or latent variable modeling. The work of Greca and Stone on the psychometric evaluation of the revised version of a social anxiety scale for children (SASC-R) provides a good example for the evaluation of concurrent validity (",{"xref":5122,":@":5125},[5123],{"#text":5124},"140",{"@_ref-type":898,"@_rid":5126},"B140",{"#text":5128},"). In this study, the authors collected data on an earlier validated version of the SASC scale consisting of 10 items, as well as the revised version, SASC-R, which had additional 16 items making a 26-item scale. The SASC consisted of two sub scales [fear of negative evaluation (FNE), social avoidance and distress (SAD)] and the SASC-R produced three new subscales (FNE, SAD-New, and SAD-General). Using a Pearson product-moment correlation, the authors examined the inter-correlations between the common subscales for FNE, and between SAD and SAD-New. With a validity coefficient of 0.94 and 0.88, respectively, the authors found evidence of concurrent validity.",{"#text":796},{"p":5131},[5132,5134,5138],{"#text":5133},"A limitation of concurrent validity is that this strategy for validity does not work with small sample sizes because of their large sampling errors. Secondly, appropriate criterion variables or “gold standards” may not be available (",{"xref":5135,":@":5137},[5136],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5139},"). This reason may account for its omission in most validation studies.",{"#text":802},{"#text":802},{"sec":5143},[5144,5145,5148,5149,5159,5160,5197,5198,5237,5238,5264,5265,5285,5286,5297],{"#text":796},{"title":5146},[5147],{"#text":2320},{"#text":796},{"p":5150},[5151,5153,5157],{"#text":5152},"Construct validity is the “extent to which an instrument assesses a construct of concern and is associated with evidence that measures other constructs in that domain and measures specific real-world criteria” (",{"xref":5154,":@":5156},[5155],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5158},"). Four indicators of construct validity are relevant to scale development: convergent validity, discriminant validity, differentiation by known groups, and correlation analysis.",{"#text":796},{"p":5161},[5162,5164,5168,5169,5173,5174,5178,5180,5184,5186,5190,5191,5195],{"#text":5163},"Convergent validity is the extent to which a construct measured in different ways yields similar results. Specifically, it is the “degree to which scores on a studied instrument are related to measures of other constructs that can be expected on theoretical grounds to be close to the one tapped into by this instrument” (",{"xref":5165,":@":5167},[5166],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":5170,":@":5172},[5171],{"#text":2358},{"@_ref-type":898,"@_rid":2360},{"#text":933},{"xref":5175,":@":5177},[5176],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":5179},"). This is best estimated through the multi-trait multi-method matrix (",{"xref":5181,":@":5183},[5182],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5185},"), although in some cases researchers have used either latent variable modeling or Pearson product-moment correlation based on Fisher's Z transformation. Evidence of convergent validity of a construct can be provided by the extent to which the newly developed scale correlates highly with other variables designed to measure the same construct (",{"xref":5187,":@":5189},[5188],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":933},{"xref":5192,":@":5194},[5193],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":5196},"). It can be invalidated by too low or weak correlations with other tests which are intended to measure the same construct.",{"#text":796},{"p":5199},[5200,5202,5206,5208,5212,5214,5218,5220,5224,5226,5230,5232,5236],{"#text":5201},"Discriminant validity is the extent to which a measure is novel and not simply a reflection of some other construct (",{"xref":5203,":@":5205},[5204],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":5207},"). Specifically, it is the “degree to which scores on a studied instrument are differentiated from behavioral manifestations of other constructs, which on theoretical grounds can be expected not to be related to the construct underlying the instrument under investigation” (",{"xref":5209,":@":5211},[5210],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5213},"). This is best estimated through the multi-trait multi method matrix (",{"xref":5215,":@":5217},[5216],{"#text":1245},{"@_ref-type":898,"@_rid":1247},{"#text":5219},"). Discriminant validity is indicated by predictably low or weak correlations between the measure of interest and other measures that are supposedly not measuring the same variable or concept (",{"xref":5221,":@":5223},[5222],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":5225},"). The newly developed construct can be invalidated by too high correlations with other tests which are intended to differ in their measurements (",{"xref":5227,":@":5229},[5228],{"#text":2358},{"@_ref-type":898,"@_rid":2360},{"#text":5231},"). This approach is critical in differentiating the newly developed construct from other rival alternatives (",{"xref":5233,":@":5235},[5234],{"#text":2836},{"@_ref-type":898,"@_rid":2838},{"#text":941},{"#text":796},{"p":5239},[5240,5242,5246,5248,5252,5254,5257,5259,5262],{"#text":5241},"Differentiation or comparison between known groups examines the distribution of a newly developed scale score over known binary items (",{"xref":5243,":@":5245},[5244],{"#text":2365},{"@_ref-type":898,"@_rid":2367},{"#text":5247},"). This is premised on previous theoretical and empirical knowledge of the performance of the binary groups. An example of best practice is seen in the work of Boateng et al. on the validation of a household water insecurity scale in Kenya. In this study, we compared the mean household water insecurity scores over households with or without ",{"italic":5249},[5250],{"#text":5251},"E. coli",{"#text":5253}," present in their drinking water. Consistent with what we knew from the extant literature, we found households with ",{"italic":5255},[5256],{"#text":5251},{"#text":5258}," present in their drinking water had higher mean water insecurity scores than households that had no ",{"italic":5260},[5261],{"#text":5251},{"#text":5263}," in drinking water. This suggested our scale could discriminate between particular known groups.",{"#text":796},{"p":5266},[5267,5269,5273,5274,5278,5280,5284],{"#text":5268},"Although correlational analysis is frequently used by several scholars, bivariate regression analysis is preferred to correlational analysis for quantifying validity (",{"xref":5270,":@":5272},[5271],{"#text":2489},{"@_ref-type":898,"@_rid":2491},{"#text":933},{"xref":5275,":@":5277},[5276],{"#text":2496},{"@_ref-type":898,"@_rid":2498},{"#text":5279},"). Regression analysis between scale scores and an indicator of the domain examined has a number of important advantages over correlational analysis. First, regression analysis quantifies the association in meaningful units, facilitating judgment of validity. Second, regression analysis avoids confounding validity with the underlying variation in the sample and therefore the results from one sample are more applicable to other samples in which the underlying variation may differ. Third, regression analysis is preferred because the regression model can be used to examine discriminant validity by adding potential alternative measures. In addition to regression analysis, alternative techniques such as analysis of standard deviations of the differences between scores and the examination of intraclass correlation coefficients (ICC) have been recommended as viable options (",{"xref":5281,":@":5283},[5282],{"#text":2496},{"@_ref-type":898,"@_rid":2498},{"#text":941},{"#text":796},{"p":5287},[5288,5290,5296],{"#text":5289},"Taken together, these methods make it possible to assess the validity of an adapted or a newly developed scale. In addition to predictive validity, existing studies in fields such as health, social, and behavioral sciences have shown that scale validity is supported if at least two of the different forms of construct validity discussed in this section have been examined. Further information about establishing validity and constructing indictors from scales can be found in Frongillo et al. (",{"xref":5291,":@":5294},[5292],{"#text":5293},"141",{"@_ref-type":898,"@_rid":5295},"B141",{"#text":941},{"#text":802},{"#text":877},{"#text":880},{"@_id":5301},"s5",{"#text":880},{"sec":5304,":@":5361,"anchorId":5363},[5305,5306,5310,5311,5327,5328,5332,5333,5355,5356,5360],{"#text":877},{"title":5307},[5308],{"#text":5309},"Conclusions",{"#text":877},{"p":5312},[5313,5315,5319,5321,5325],{"#text":5314},"In sum, we have sought to give an overview of the key steps in scale development and validation (Figure ",{"xref":5316,":@":5318},[5317],{"#text":896},{"@_ref-type":995,"@_rid":996},{"#text":5320},") as well as to help the reader understand how one might approach each step (Table ",{"xref":5322,":@":5324},[5323],{"#text":896},{"@_ref-type":2005,"@_rid":2509},{"#text":5326},"). We have also given a basic introduction to the conceptual and methodological underpinnings of each step.",{"#text":877},{"p":5329},[5330],{"#text":5331},"Because scale development is so complicated, this should be considered a primer, i.e., a “jumping off point” for anyone interested in scale development. The technical literature and examples of rigorous scale development mentioned throughout will be important for readers to pursue. There are a number of matters not addressed here, including how to interpret scale output, the designation of cut-offs, when indices, rather than scales, are more appropriate, and principles for re-testing scales in new populations. Also, this review leans more toward the classical test theory approach to scale development; a comprehensive review on IRT modeling will be complementary. We hope this review helps to ease readers into the literature, but space precludes consideration of all these topics.",{"#text":877},{"p":5334},[5335,5337,5341,5343,5347,5349,5353],{"#text":5336},"The necessity of the nine steps that we have outlined here (Table ",{"xref":5338,":@":5340},[5339],{"#text":896},{"@_ref-type":2005,"@_rid":2509},{"#text":5342},", Figure ",{"xref":5344,":@":5346},[5345],{"#text":896},{"@_ref-type":995,"@_rid":996},{"#text":5348},") will vary from study to study. While studies focusing on developing scales ",{"italic":5350},[5351],{"#text":5352},"de novo",{"#text":5354}," may use all nine steps, others, e.g., those that set out to validate existing scales, may end up using only the last four steps. Resource constraints, including time, money, and participant attention and patience are very real, and must be acknowledged as additional limits to rigorous scale development. We cannot state which steps are the most important; difficult decisions about which steps to approach less rigorously can only be made by each scale developer, based on the purpose of the research, the proposed end-users of the scale, and resources available. It is our hope, however, that by outlining the general shape of the phases and steps in scale development, researchers will be able to purposively choose the steps that they will include, rather than omitting a step out of lack of knowledge.",{"#text":877},{"p":5357},[5358],{"#text":5359},"Well-designed scales are the foundation of much of our understanding of a range of phenomena, but ensuring that we accurately quantify what we purport to measure is not a simple matter. By making scale development more approachable and transparent, we hope to facilitate the advancement of our understanding of a range of health, social, and behavioral outcomes.",{"#text":880},{"@_sec-type":5362,"@_id":5363},"conclusions","s6",{"#text":880},{"sec":5366,":@":5392,"anchorId":5394},[5367,5368,5372,5373,5377,5378,5391],{"#text":877},{"title":5369},[5370],{"#text":5371},"Author contributions",{"#text":877},{"p":5374},[5375],{"#text":5376},"GB and SY developed the first draft of the scale development and validation manuscript. All authors participated in the editing and critical revision of the manuscript and approved the final version of the manuscript for publication.",{"#text":877},{"sec":5379},[5380,5381,5385,5386,5390],{"#text":802},{"title":5382},[5383],{"#text":5384},"Conflict of interest statement",{"#text":802},{"p":5387},[5388],{"#text":5389},"The authors declare that the research was conducted in the absence of any commercial or financial relationships that could be construed as a potential conflict of interest.",{"#text":877},{"#text":880},{"@_id":5393},"s7","h8",{"#text":5396},"\n  ",[],[5399,5422,5437,5459,5473],{"title":5371,"order":767,"content":5400,"anchorId":5394},[5401,5402,5405,5406,5409,5410,5421],{"#text":877},{"title":5403},[5404],{"#text":5371},{"#text":877},{"p":5407},[5408],{"#text":5376},{"#text":877},{"sec":5411},[5412,5413,5416,5417,5420],{"#text":802},{"title":5414},[5415],{"#text":5384},{"#text":802},{"p":5418},[5419],{"#text":5389},{"#text":877},{"#text":880},{"title":5423,"order":773,"content":5424,"anchorId":5436},"Funding",[5425,5426,5435],{"#text":802},{"p":5427},[5428,5429,5433],{"#text":796},{"bold":5430},[5431],{"#text":5432},"Funding.",{"#text":5434}," Funding for this work was obtained by SY through the National Institute of Mental Health—R21 MH108444. The content is solely the responsibility of the authors and does not necessarily represent the official views of the National Institute of Mental Health or the National Institutes of Health.",{"#text":877},"h9",{"title":5438,"order":599,"content":5439,"anchorId":5458},"Acknowledgments",[5440,5441,5457],{"#text":877},{"p":5442},[5443,5445,5449,5451,5455],{"#text":5444},"We would like to acknowledge the importance of the works of several scholars of scale development and validation used in developing this primer, particularly Robert DeVellis, Tenko Raykov, George Marcoulides, David Streiner, and Betsy McCoach. We would also like to acknowledge the help of Josh Miller of Northwestern University for assisting with design of Figure ",{"xref":5446,":@":5448},[5447],{"#text":896},{"@_ref-type":995,"@_rid":996},{"#text":5450}," and development of Table ",{"xref":5452,":@":5454},[5453],{"#text":896},{"@_ref-type":2005,"@_rid":2509},{"#text":5456},", and we thank Zeina Jamuladdine for helpful comments on tests of unidimensionality.",{"#text":880},"h10",{"title":5460,"order":5461,"content":5462,"anchorId":5472},"Conflict of interest",8,[5463,5464,5467,5468,5471],{"#text":802},{"title":5465},[5466],{"#text":5384},{"#text":802},{"p":5469},[5470],{"#text":5389},{"#text":877},"h11",{"title":5474,"order":5475,"content":5476,"anchorId":6008},"Abbreviations",17,[5477,5478,6007],{"#text":877},{"def-list":5479},[5480,5481,5484,5485,5502,5503,5520,5521,5538,5539,5556,5557,5574,5575,5592,5593,5610,5611,5628,5629,5646,5647,5664,5665,5682,5683,5700,5701,5718,5719,5736,5737,5754,5755,5772,5773,5790,5791,5808,5809,5826,5827,5844,5845,5862,5863,5880,5881,5898,5899,5916,5917,5934,5935,5952,5953,5970,5971,5988,5989,6006],{"#text":802},{"title":5482},[5483],{"#text":5474},{"#text":802},{"def-item":5486},[5487,5488,5492,5493,5501],{"#text":796},{"term":5489},[5490],{"#text":5491},"A-CASI",{"#text":796},{"def":5494},[5495,5496,5500],{"#text":1053},{"p":5497},[5498],{"#text":5499},"audio computer self-assisted interviewing",{"#text":796},{"#text":802},{"#text":802},{"def-item":5504},[5505,5506,5510,5511,5519],{"#text":796},{"term":5507},[5508],{"#text":5509},"ASES",{"#text":796},{"def":5512},[5513,5514,5518],{"#text":1053},{"p":5515},[5516],{"#text":5517},"adherence self-efficacy scale",{"#text":796},{"#text":802},{"#text":802},{"def-item":5522},[5523,5524,5528,5529,5537],{"#text":796},{"term":5525},[5526],{"#text":5527},"CAPI",{"#text":796},{"def":5530},[5531,5532,5536],{"#text":1053},{"p":5533},[5534],{"#text":5535},"computer assisted personal interviewing",{"#text":796},{"#text":802},{"#text":802},{"def-item":5540},[5541,5542,5546,5547,5555],{"#text":796},{"term":5543},[5544],{"#text":5545},"CFA",{"#text":796},{"def":5548},[5549,5550,5554],{"#text":1053},{"p":5551},[5552],{"#text":5553},"confirmatory factor analysis",{"#text":796},{"#text":802},{"#text":802},{"def-item":5558},[5559,5560,5564,5565,5573],{"#text":796},{"term":5561},[5562],{"#text":5563},"CASIC",{"#text":796},{"def":5566},[5567,5568,5572],{"#text":1053},{"p":5569},[5570],{"#text":5571},"computer assisted survey information collection builder",{"#text":796},{"#text":802},{"#text":802},{