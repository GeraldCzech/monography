ic-health/for-authors/author-guidelines",{"text":230,"url":231,"target":27,"ariaLabel":28},"Editor guidelines","https://www.frontiersin.org/journals/public-health/for-authors/editor-guidelines",{"text":233,"url":234,"target":27,"ariaLabel":28},"Publishing fees","https://www.frontiersin.org/journals/public-health/for-authors/publishing-fees",{"text":236,"url":237,"target":27,"ariaLabel":28},"Submission checklist","https://www.frontiersin.org/journals/public-health/for-authors/submission-checklist",{"text":239,"url":240,"target":27,"ariaLabel":28},"Contact editorial office","https://www.frontiersin.org/journals/public-health/for-authors/contact-editorial-office",[242,245],{"text":243,"url":244,"target":27,"ariaLabel":28},"All journals","https://www.frontiersin.org/journals",{"text":246,"url":247,"target":27,"ariaLabel":28},"All articles","https://www.frontiersin.org/articles",[249,252,254],{"text":250,"url":251,"target":27,"ariaLabel":28},"Articles","articles",{"text":66,"url":253,"target":27,"ariaLabel":28},"research-topics",{"text":255,"url":256,"target":27,"ariaLabel":28},"Editorial board","editors",{"text":258,"url":259,"target":80,"ariaLabel":258},"Help center","https://helpcenter.frontiersin.org",{"blocks":261,"socialLinks":315,"copyright":339,"termsAndConditionsUrl":340,"privacyPolicyUrl":341,"accessibilityStatementUrl":342},[262,276,286,300],{"title":263,"links":264},"Guidelines",[265,267,270,273,275],{"text":227,"url":266,"target":27,"ariaLabel":28},"https://www.frontiersin.org/guidelines/author-guidelines",{"text":268,"url":269,"target":27,"ariaLabel":28},"Services for authors","https://www.frontiersin.org/for-authors/author-services",{"text":271,"url":272,"target":27,"ariaLabel":28},"Policies and publication ethics","https://www.frontiersin.org/guidelines/policies-and-publication-ethics",{"text":230,"url":274,"target":27,"ariaLabel":28},"https://www.frontiersin.org/guidelines/editor-guidelines",{"text":72,"url":73,"target":27,"ariaLabel":28},{"title":277,"l