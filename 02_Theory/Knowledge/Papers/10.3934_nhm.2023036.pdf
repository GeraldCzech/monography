    <title>On the spread of charitable behavior in a social network: a model based on game theory</title>
	    
	<meta name="WT.cg_n" content="Networks and Heterogeneous Media"/>
    	<meta name="prism.issn" content="1556-1801"/>
	<meta name="citation_issn" content="1556-1801"/>
