	        <div class="article-main-mid fl bgwhite gongshi">
				<div class="clear">
					<div class="article-journal fl" >
	            		<h3 class="journal-con" ><a href="/journal/nhm" class="journal-tit">
					     Networks and Heterogeneous Media
		        		 </a></h3>
		        		 
		        		 <div  class="article-list-time">
		        		 
					        <font >  2023, 						        <span><a href="/nhm/article/archives" class="mainColor">Volume 18</a>, </span> <a href="/nhm/article/2023/2/archive-articles" class="mainColor">Issue 2</a><span>:</span>  <span>842-854</span>.					        </font>
							<font>doi: <a href="/article/doi/10.3934/nhm.2023036" target="_blank" class="mainColor">10.3934/nhm.2023036</a></font>					    </div>
					    
					    
	            	</div>
					<div class="fr changebtn" >
																					<a href="/article/doi/10.3934/nhm.2023035" class="page-btn prev-page fl">Previous Article</a>
														
												
