core/communities/28f14fed-0113-4065-86b9-0f31c5114f01/logo"},"subcommunities":{"href":"https://repositorium.uminho.pt/server/api/core/communities/28f14fed-0113-4065-86b9-0f31c5114f01/subcommunities"},"parentCommunity":{"href":"https://repositorium.uminho.pt/server/api/core/communities/28f14fed-0113-4065-86b9-0f31c5114f01/parentCommunity"},"adminGroup":{"href":"https://repositorium.uminho.pt/server/api/core/communities/28f14fed-0113-4065-86b9-0f31c5114f01/adminGroup"},"self":{"href":"https://repositorium.uminho.pt/server/api/core/communities/28f14fed-0113-4065-86b9-0f31c5114f01"}},"_name":"Escola de Psicologia | School of Psychology","id":"28f14fed-0113-4065-86b9-0f31c5114f01","uuid":"28f14fed-0113-4065-86b9-0f31c5114f01","type":"community","metadata":{"dc.description":[{"uuid":"b4d8fe66-af16-4c59-ae9e-d65c3e1495c0","language":null,"value":"\u003Cbr>\u003Cp align=\"justify\">A Escola de Psicologia posiciona-se estrategicamente num quadro de referência internacional, procurando diferenciar-se enquanto instituição ac​adémica de referência na promoção de uma visão da Psicologia como ciência de base experimental e como uma prática profissional de base científica. Uma visão da psicologia como uma ciência básica de forte relevância social a par de uma prática profissional de base científica, tem implicações na forma como são, estrategicamente, enquadrados os projetos da Escola: Ensino, Investigação e a Interface com a comunidade.\u003C/p> \r\n\r\n\u003Cp align=\"justify\">The School of Psychology is strategically positioned in an international reference framework, aiming to stand out as an academic institution of reference in the promotion of a vision of Psychology as an experimental science of basis and as a professional practice of scientific basis. A vision of Psychology as a basic science of strong social relevance along with a scientific based professional practice has impact in the way the School projects are, strategically, framed: Teaching, Research and interaction with the community. \u003C/p>","place":0,"authority":null,"confidence":-1}],"dc.description.abstract":[{"uuid":"7b1cfa38-f5a6-4d8d-b373-a8c1c2daceea","language":null,"value":"EPsi","place":0,"authority":null,"confidence":-1}],"dc.description.tableofcontents":[{"uuid":"965b510d-71cf-4353-82bd-50d2990a3d77","language":null,"value":"\u003Ctable class=\"news\" width=\"100%\" height=\"100%\">   \u003Ctr>  \u003Ctd valign=\"top\" bgcolor=\"#E7C3C3\">\r\n\u003Cb>Escola de Psicologia da Universidade do Minho (EPUM)\u003C/b>\u003Cbr>\u003Cbr>\r\n\r\nUniversidade do Minho\u003Cbr>\r\nCampus de Gualtar\u003Cbr> \r\n4710-057 Braga\u003Cbr> \r\nTel.: 253 604220, 253 604683\r\n\u003Cbr>\r\nFax: 253 604224\r\n\u003Cbr>\r\nEmail: secescola@psi.uminho.pt \u003Cbr>\r\nURL: www.psi.umi​nho.pt\r\n\r\n\u003C/td>\u003C/tr>\u003C/table>","place":0,"authority":null,"confidence":-1}],"dc.identifier.uri":[{"uuid":"918aa291-c214-4960-9e75-14de7d2c47c4","language":null,"value":"https://repositorium.uminho.pt/handle/1822/44200","place":0,"authority":null,"confidence":-1}],"dc.title":[{"uuid":"55746c05-7135-4d69-be7a-fc88b7dff4b9","language":null,"value":"Escola de Psicologia | School of Psychology","place":0,"authority":null,"confidence":-1}]}},"timeCompleted":1784830845792,"msToLive":900000,"requestUUIDs":["client/7e6725eb-c63e-479a-b2e2-b74c619cbda3"],"dependentRequestUUIDs":[],"isDirty":false,"patches":[],"alternativeLinks":["https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4/parentCommunity"]},"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4":{"data":{"archivedItemsCount":3922,"_links":{"collections":{"href":"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4/collections"},"logo":{"href":"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4/logo"},"subcommunities":{"href":"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4/subcommunities"},"parentCommunity":{"href":"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4/parentCommunity"},"adminGroup":{"href":"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4/adminGroup"},"self":{"href":"https://repositorium.uminho.pt/server/api/core/communities/f42d4e97-7a2b-4f51-a4b9-ba07807376d4"}},"_name":"Centro de Investigação em Psicologia","id":"f42d4e97-7a2b-4f51-a4b9-ba07807376d4","uuid":"f42d4e97-7a2b-4f51-a4b9-ba07807376d4","type":"community","metadata":{"dc.description":[{"uuid":"4355daf9-e4f6-42d2-bae1-fe111b2cac40","language":null,"value":"\u003Cbr>\u003Cp align=\"justify\">CIPsi is the University of Minho’s center for research in Psychology. Its primary goal is to foster the scientific study of behavior in a variety of domains, ranging from the more basic to the more applied ones. The Center helps its members develop research skills, secure external funds, attend foreign conferences, and publish their works. It also sponsors national conferences and workshops, brings prominent scholars from other institutions for public guest lectures, and helps to staff and maintain laboratory facilities and equipment. \u003C/p>","place":0,"authority":null,"confidence":-1}],"dc.description.abstract":[{"uuid":"8bf5d0df-40b5-470c-b3d5-0723cb028668","language":null,"value":"CIPsi","place":0,"authority":null,"confidence":-1}],"dc.description.tableofcontents":[{"uuid":"45e9798e-c097-4a5e-a9c7-4526cb6e6d0d","language":null,"value":"\u003Ctable class=\"news\" width=\"100%\" height=\"100%\">   \u003Ctr>  \u003Ctd valign=\"top\" bgcolor=\"#cccccc\">\u003Cb>\r\nCentro de Investigação em Psicologia (CIPsi)\u003C/b>\u003Cbr>\u003Cbr>\r\nUniversidade do Minho\u003Cbr>\r\n\r\nEscola de Psicologia \u003Cbr>\r\nCampus de Gualtar\u003Cbr>\r\n4710-057 Braga\u003Cbr> \r\nPortugal\u003Cbr>\u003Cbr>\r\n\r\n\u003C/td>\u003C/tr>\u003C/table>","place":0,"authority":null,"confidence":-1}],"dc.identifier.uri":[{"uuid":"4a5a2835-51a2-42a6-8e51-8b7f766231b7","language":null,"value":"https://repositorium.uminho.pt/handle/1822/969","place":0,"authority":null,"confidence":-1}],"dc.title":[{"uuid":"7a1228cc-6a7c-441f-be9f-29f354882075","language":null,"value":"Centro de Investigação em Psicologia","place":0,"authority":null,"confidence":-1}]}},"timeCompleted":1784830845792,"msToLive":900000,"requestUUIDs":["client/7e6725eb-c63e-479a-b2e2-b74c619cbda3"],"dependentRequestUUIDs":[],"isDirty":false,"patches":[],"alternativeLinks":["https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/parentCommunity"]},"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3":{"data":{"archivedItemsCount":2265,"_links":{"harvester":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/harvester"},"itemtemplate":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/itemtemplate"},"license":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/license"},"logo":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/logo"},"mappedItems":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/mappedItems"},"parentCommunity":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/parentCommunity"},"adminGroup":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/adminGroup"},"submittersGroup":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc698-96e6-4660-9a5d-7593d77f3ba3/submittersGroup"},"itemReadGroup":{"href":"https://repositorium.uminho.pt/server/api/core/collections/c7cbc6