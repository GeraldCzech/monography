db0-4db7-852b-fef55999b3be/version"},"templateItemOf":{"href":"https://repositorium.uminho.pt/server/api/core/items/c69dd92f-edb0-4db7-852b-fef55999b3be/templateItemOf"},"thumbnail":{"href":"https://repositorium.uminho.pt/server/api/core/items/c69dd92f-edb0-4db7-852b-fef55999b3be/thumbnail"},"self":{"href":"https://repositorium.uminho.pt/server/api/core/items/c69dd92f-edb0-4db7-852b-fef55999b3be"}},"_name":"The intention-behaviour gap: An empirical examination of an integrative perspective to explain exercise behaviour","id":"c69dd92f-edb0-4db7-852b-fef55999b3be","uuid":"c69dd92f-edb0-4db7-852b-fef55999b3be","type":"item","metadata":{"dc.contributor.author":[{"uuid":"33ae3dc1-078f-4206-901b-1f0f7f8b9bfd","language":"por","value":"Gomes, A. Rui","place":0,"authority":"2057","confidence":600},{"uuid":"482384df-ef67-46e7-a425-196606050de4","language":"por","value":"Gonçalves, A. Manuela","place":1,"authority":"1044","confidence":600},{"uuid":"12e03e61-5a86-4e11-82eb-0770416b1965","language":"por","value":"Maddux, James E.","place":2,"authority":null,"confidence":0},{"uuid":"6504cbd5-a75b-41c8-b396-c395cfb337fb","language":"por","value":"Carnneiro, Luís","place":3,"authority":null,"confidence":0}],"dc.date.accessioned":[{"uuid":"17a7fc02-aa12-4596-a11d-09577b5e42b1","language":null,"value":"2018-11-27T10:00:28Z","place":0,"authority":null,"confidence":-1}],"dc.date.available":[{"uuid":"ad7640f2-9eb6-42b1-89fd-28cfe078a234","language":null,"value":"2018-11-27T10:00:28Z","place":0,"authority":null,"confidence":-1}],"dc.date.issued":[{"uuid":"f409f06a-cbdf-4d9d-9e1c-1c9efd477192","language":null,"value":"2018","place":0,"authority":null,"confidence":-1}],"dc.date.submitted":[{"uuid":"3320d7ba-bb02-498f-877a-b166b60337ca","language":null,"value":"2017","place":0,"authority":null,"confidence":-1}],"dc.description.abstract":[{"uuid":"4ca41ed3-7ca3-4789-9899-84ea6d45cded","language":"por","value":"This study tested the Theory of Planned Behavior (TPB) in conjunction with two sets of variables from the Health Action Process Approach (HAPA) and the Subjective Exercise Experience Scale (SEE) to predict exercise behavior. This study included 454 participants who exercised in a fitness center. We collected measures of the TPB (attitudes, subjective norms, perceived behavioral control, and intention), HAPA (planning), and SEE (positive well-being, psychological distress, and fatigue) and assessed exercise behavior at a three-month follow-up. Structural equation modeling found partial support for the TPB model (explaining 10% of the variance in exercise behavior) and adequate fit indices for an adjusted model of the TPB that includes a positive well-being dimension (explaining 11% of the variance in exercise behavior). In sum, the original TPB partially predicts exercise behavior; when considered together with other predictors, limited evidence was found for its utility in explaining exercise behavior.","place":0,"authority":null,"confidence":-1}],"dc.description.publicationversion":[{"uuid":"3ddc91b6-e064-41c5-9236-e16b8a33e21d","language":"por","value":"info:eu-repo/semantics/submittedVersion","place":0,"authority":null,"confidence":-1}],"dc.description.sponsorship":[{"uuid":"bbdde73b-6ff2-49fd-b5e2-6a2d23566feb","language":"por","value":"This study was conducted at Psychology Research Centre (UID/PSI/01662/2013), University of Minho, and supported by the Portuguese Foundation for Science and Technology and the Portuguese Ministry of Science, Technology and Higher Education through national funds and co-financed by FEDER through COMPETE2020 under the PT2020 Partnership Agreement (POCI-01-0145-FEDER-007653).","place":0,"authority":null,"confidence":-1}],"dc.distribution":[{"uuid":"9e42df29-5d46-439d-b645-b8ac203a834b","language":"por","value":"international","place":0,"authority":null,"confidence":-1}],"dc.identifier.citation":[{"uuid":"c17d7e18-c907-4d3d-acd7-21f4017f64ef","language":"por","value":"Gomes, A.R., Gonçalves, M.A., Maddux, J.E., & Carneiro, L. (2018). The intention-behaviour gap: An empirical examination of an integrative perspective to explain exercise behaviour. International Journal of Sport and Exercise Psychology, 16(6), 607-621","place":0,"authority":null,"confidence":-1}],"dc.identifier.doi":[{"uuid":"08eb3f32-dbf8-4ca6-b3b7-298b71113f8a","language":"por","value":"10.1080/1612197X.2017.1321030","place":0,"authority":null,"confidence":-1}],"dc.identifier.eissn":[{"uuid":"79a6c0e5-b99a-4c64-bc87-c11e10110c04","language":"por","value":"1557-251X","place":0,"authority":null,"confidence":-1}],"dc.identifier.issn":[{"uuid":"98974c7d-dd21-467b-8df8-40a31df24b5a","language":"por","value":"1612-197X","place":0,"authority":null,"confidence":-1}],"dc.identifier.uri":[{"uuid":"f35f55db-bc34-47c1-93bc-fd461cccd763","language":null,"value":"https://hdl.handle.net/1822/57082","place":0,"authority":null,"confidence":-1}],"dc.language.iso":[{"uuid":"832e47f6-8bb1-45d8-83dc-e297a1fb070d","language":"por","value":"eng","place":0,"authority":null,"confidence":-1}],"dc.peerreviewed":[{"uuid":"b85da7fd-4a9a-410c-9bba-7c31292030aa","language":"por","value":"yes","place":0,"authority":null,"confidence":-1}],"dc.publisher":[{"uuid":"0994c211-7480-4911-8007-0f71d77fbd8e","language":"por","value":"Taylor & Francis","place":0,"authority":"13012","confidence":600}],"dc.relation":[{"uuid":"43cd1cfb-2375-4a6c-9e25-f41cdc9e78c1","language":"por","value":"info:eu-repo/grantAgreement/FCT/5876/147227/PT","place":0,"authority":"74247","confidence":600}],"dc.relation.publisherversion":[{"uuid":"5caccba9-bd2c-4136-8b3c-243a110c5467","language":"por","value":"https://www.tandfonline.com/doi/full/10.1080/1612197X.2017.1321030","place":0,"authority":null,"confidence":-1}],"dc.rights":[{"uuid":"dae6e16d-ed9e-47b5-9007-c69ce4734fa1","language":"por","value":"openAccess","place":0,"authority":null,"confidence":-1}],"dc.rights.uri":[{"uuid":"f92b91b2-f6e7-48e0-8303-fc0964092349","language":"por","value":"http://creativecommons.